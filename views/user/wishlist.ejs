<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Wishlist – Blush Berry</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Poppins',sans-serif;background:#fff;color:#333;}
    a{text-decoration:none;color:inherit;}
    .page-header{background:linear-gradient(110deg,#fff8f9 55%,#fce8ed 100%);padding:32px 48px 24px;}
    .page-header p{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#c0415a;margin-bottom:6px;}
    .page-header h1{font-family:'Playfair Display',serif;font-size:32px;font-weight:900;color:#1a1a2e;}
    .breadcrumb{font-size:12px;color:#aaa;margin-top:8px;display:flex;gap:6px;}
    .breadcrumb a{color:#c0415a;}
    .content{padding:36px 48px 60px;}
    .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;}
    .card{border:1px solid #f0e6e6;border-radius:10px;overflow:hidden;background:#fff;cursor:pointer;transition:all .3s;}
    .card:hover{box-shadow:0 12px 36px rgba(0,0,0,0.1);transform:translateY(-4px);}
    .card-img{height:180px;background:linear-gradient(135deg,#fff5f7,#fce8ed);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;}
    .card-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
    .card:hover .card-img img{transform:scale(1.06);}
    .wish-btn{position:absolute;top:10px;left:10px;background:#fff;border:1px solid #f0e6e6;border-radius:50%;width:30px;height:30px;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#c0415a;}
    .card-body{padding:14px;}
    .card-name{font-size:13px;font-weight:500;color:#1a1a2e;margin-bottom:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .card-price{font-size:14px;font-weight:700;color:#c0415a;margin-bottom:10px;}
    .card-orig{font-size:11px;color:#ccc;text-decoration:line-through;margin-left:6px;}
    .btn-cart{width:100%;padding:9px;background:#1a1a2e;color:#fff;border:none;border-radius:4px;font-size:11px;font-weight:600;letter-spacing:.5px;cursor:pointer;transition:background .2s;}
    .btn-cart:hover{background:#c0415a;}
    .btn-cart:disabled{background:#ccc;cursor:not-allowed;}
    .empty{text-align:center;padding:80px 20px;}
    .empty .icon{font-size:56px;margin-bottom:16px;}
    .empty h3{font-family:'Playfair Display',serif;font-size:22px;color:#1a1a2e;margin-bottom:8px;}
    .empty p{font-size:13px;color:#aaa;margin-bottom:24px;}
    .empty a{display:inline-block;padding:11px 28px;background:#c0415a;color:#fff;border-radius:4px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;}
    .toast{position:fixed;bottom:28px;right:28px;padding:12px 22px;border-radius:6px;font-size:13px;font-weight:500;color:#fff;z-index:9999;opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none;}
    .toast.show{opacity:1;transform:translateY(0);}
    .toast.success{background:#22b573;}
    .toast.error{background:#e05555;}
    @media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr);}.content{padding:20px;}.page-header{padding:24px 20px;}}
    @media(max-width:480px){.grid{grid-template-columns:1fr;}}
  </style>
</head>
<body>
  <%- include('../partials/user/header') %>

  <div class="page-header">
    <p>Blush Berry</p>
    <h1>My Wishlist</h1>
    <div class="breadcrumb">
      <a href="/">Home</a> <span>›</span>
      <a href="/products">Shop</a> <span>›</span>
      <span style="color:#555;">Wishlist</span>
    </div>
  </div>

  <div class="content">
    <% if(!products || products.length === 0){ %>
    <div class="empty">
      <div class="icon">♡</div>
      <h3>Your wishlist is empty</h3>
      <p>Save items you love and come back to them later.</p>
      <a href="/products">Browse Products</a>
    </div>

    <% } else { %>
    <p style="font-size:13px;color:#aaa;margin-bottom:24px;"><%= products.length %> item<%= products.length !== 1 ? 's' : '' %> saved</p>
    <div class="grid">
      <% products.forEach(product => { %>
      <div class="card" onclick="window.location='/products/<%= product._id %>'">
        <div class="card-img">
          <% if(product.images && product.images[0]){ %>
            <img src="<%= product.images[0] %>" alt="<%= product.name %>">
          <% } else { %>
            <span style="font-size:36px;">💄</span>
          <% } %>
          <% if(!product.inStock){ %>
            <span style="position:absolute;top:10px;right:10px;background:#999;color:#fff;font-size:9px;padding:3px 8px;border-radius:20px;font-weight:600;">SOLD OUT</span>
          <% } %>
          <button class="wish-btn" onclick="removeFromWishlist(event,'<%= product._id %>',this)">♥</button>
        </div>
        <div class="card-body">
          <p class="card-name" title="<%= product.name %>"><%= product.name %></p>
          <div style="margin-bottom:10px;">
            <span class="card-price">₹<%= product.displayPrice.toFixed(2) %></span>
            <% if(product.displayOffer > 0){ %>
              <span class="card-orig">₹<%= product.originalPrice.toFixed(2) %></span>
            <% } %>
          </div>
          <% if(product.inStock){ %>
          <button class="btn-cart" onclick="addToCart(event,'<%= product._id %>')">ADD TO CART</button>
          <% } else { %>
          <button class="btn-cart" disabled>OUT OF STOCK</button>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="toast" id="toast"></div>
  <%- include('../partials/user/footer') %>

  <script>
    function showToast(msg, type='success'){
      const t = document.getElementById('toast')
      t.textContent = msg
      t.className = `toast ${type} show`
      setTimeout(() => t.classList.remove('show'), 3000)
    }

    function removeFromWishlist(e, productId, btn){
      e.stopPropagation()
      fetch('/wishlist/toggle',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ productId })
      })
      .then(r => r.json())
      .then(data => {
        if(data.success){
          const card = btn.closest('.card')
          card.style.transition = 'opacity .3s'
          card.style.opacity = '0'
          setTimeout(() => { card.remove(); checkEmpty() }, 300)
          showToast('Removed from wishlist')
        }
      })
      .catch(() => showToast('Something went wrong','error'))
    }

    function addToCart(e, productId){
      e.stopPropagation()
      const btn = e.currentTarget
      btn.textContent = 'Adding…'
      btn.disabled = true
      fetch('/cart/add',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ productId, quantity:1 })
      })
      .then(r => r.json())
      .then(data => {
        if(data.success){
          showToast('Added to cart! 🛍')
          btn.textContent = '✓ Added'
          btn.style.background = '#22b573'
          const badge = document.getElementById('cartCount')
          if(badge && data.cartCount) badge.textContent = data.cartCount
          // remove from wishlist UI after adding to cart
          setTimeout(() => {
            const card = btn.closest('.card')
            card.style.transition = 'opacity .3s'
            card.style.opacity = '0'
            setTimeout(() => { card.remove(); checkEmpty() }, 300)
          }, 1000)
        } else {
          btn.textContent = 'ADD TO CART'
          btn.disabled = false
          if(data.redirect) window.location.href = data.redirect
          else showToast(data.message || 'Could not add','error')
        }
      })
      .catch(() => {
        btn.textContent = 'ADD TO CART'
        btn.disabled = false
      })
    }

    function checkEmpty(){
      if(document.querySelectorAll('.card').length === 0) location.reload()
    }
  </script>
</body>
</html>