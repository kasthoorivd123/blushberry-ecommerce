<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= product.name %> – Blush Berry</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Poppins',sans-serif;background:#fff;color:#333;overflow-x:hidden;}
    a{text-decoration:none;color:inherit;}

    /* ── Breadcrumb ── */
    .breadcrumb{padding:18px 48px;font-size:12px;color:#aaa;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
    .breadcrumb a{color:#c0415a;}
    .breadcrumb a:hover{text-decoration:underline;}
    .breadcrumb-sep{color:#ddd;}

    /* ── Main layout ── */
    .detail-wrap{display:flex;gap:56px;padding:0 48px 60px;align-items:flex-start;}
    .col-images{width:480px;min-width:480px;position:sticky;top:20px;}
    .col-info{flex:1;}

    /* ── Image gallery ── */
    .main-img-wrap{position:relative;width:100%;height:420px;border-radius:14px;overflow:hidden;background:#fce8ed;cursor:zoom-in;margin-bottom:14px;}
    .main-img-wrap img{width:100%;height:100%;object-fit:cover;transition:opacity 0.3s ease, transform 0.1s ease;}
    .main-img-wrap.zoomed img{transform:scale(2);cursor:zoom-out;}
    .main-img-wrap.zoomed{cursor:zoom-out;}
    .main-img-wrap.fading img{opacity:0;}
    .thumb-row{display:flex;gap:10px;flex-wrap:wrap;}
    .thumb{width:76px;height:76px;border-radius:8px;overflow:hidden;border:2px solid transparent;cursor:pointer;transition:border-color .2s, opacity .2s;background:#fce8ed;flex-shrink:0;}
    .thumb img{width:100%;height:100%;object-fit:cover;}
    .thumb.active{border-color:#c0415a;}
    .thumb:hover{border-color:#e8a0b0;}

    .zoom-hint{position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,0.35);color:#fff;font-size:10px;padding:4px 9px;border-radius:20px;pointer-events:none;transition:opacity .3s;}

    .shade-gallery-indicator{
      display:none;align-items:center;gap:5px;
      background:rgba(192,65,90,0.1);border:1px solid rgba(192,65,90,0.25);
      color:#c0415a;font-size:10px;font-weight:500;
      padding:4px 10px;border-radius:999px;
      margin-bottom:10px;width:fit-content;
    }
    .shade-gallery-indicator.visible{display:flex;}

    /* ── Info column ── */
    .prod-brand{font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#c0415a;margin-bottom:8px;}
    .prod-title{font-family:'Playfair Display',serif;font-size:30px;font-weight:700;color:#1a1a2e;line-height:1.2;margin-bottom:10px;}
    .prod-category{font-size:12px;color:#aaa;margin-bottom:14px;}

    .rating-row{display:flex;align-items:center;gap:10px;margin-bottom:18px;}
    .stars-display{display:flex;gap:2px;}
    .star{font-size:16px;color:#e8a826;}
    .star.empty{color:#ddd;}
    .rating-num{font-size:14px;font-weight:600;color:#1a1a2e;}
    .rating-count{font-size:12px;color:#aaa;}

    /* ── Price block ── */
    .price-block{background:#fffafb;border:1px solid #f0e6e8;border-radius:10px;padding:18px 20px;margin-bottom:20px;}
    .price-main{font-size:28px;font-weight:700;color:#c0415a;}
    .price-orig{font-size:16px;color:#ccc;text-decoration:line-through;margin-left:10px;}
    .offer-tag{display:inline-block;background:#fce8ed;color:#c0415a;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;margin-left:8px;}

    /* ✅ NEW: save amount row */
    .price-save{font-size:12px;color:#22b573;font-weight:600;margin-top:6px;}

    .price-per-shade{font-size:12px;color:#aaa;margin-top:4px;}

    .stock-status{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;padding:5px 12px;border-radius:20px;margin-top:10px;}
    .stock-in{background:#e8f8f0;color:#22b573;}
    .stock-low{background:#fff8e6;color:#e8a826;}
    .stock-out{background:#fce8e8;color:#e05555;}
    .stock-dot{width:7px;height:7px;border-radius:50%;background:currentColor;}

    .section-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#888;margin-bottom:10px;font-weight:500;}
    .shade-selector{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px;}
    .shade-btn{display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;padding:8px 10px;border:2px solid transparent;border-radius:8px;transition:all .2s;background:#fffafb;}
    .shade-btn:hover{border-color:#e8a0b0;}
    .shade-btn.active{border-color:#c0415a;background:#fce8ed;}
    .shade-btn.out-of-stock{opacity:.45;cursor:not-allowed;}
    .shade-swatch{width:32px;height:32px;border-radius:50%;border:1px solid #eee;}
    .shade-name{font-size:10px;color:#666;text-align:center;max-width:52px;line-height:1.2;}
    .shade-price{font-size:10px;color:#c0415a;font-weight:600;}

    .qty-cart-row{display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap;}
    .qty-wrap{display:flex;align-items:center;border:1px solid #e8d8dc;border-radius:6px;overflow:hidden;}
    .qty-btn{width:36px;height:42px;background:#fffafb;border:none;font-size:18px;cursor:pointer;color:#c0415a;transition:background .2s;display:flex;align-items:center;justify-content:center;}
    .qty-btn:hover{background:#fce8ed;}
    .qty-input{width:48px;height:42px;border:none;border-left:1px solid #e8d8dc;border-right:1px solid #e8d8dc;text-align:center;font-size:14px;font-family:'Poppins',sans-serif;color:#1a1a2e;outline:none;}
    .btn-add-cart{flex:1;padding:12px 24px;background:#1a1a2e;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;cursor:pointer;transition:background .2s;}
    .btn-add-cart:hover{background:#c0415a;}
    .btn-add-cart:disabled{background:#ccc;cursor:not-allowed;}
    .btn-wishlist{width:44px;height:44px;border:1px solid #e8d8dc;border-radius:6px;background:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;}
    .btn-wishlist:hover{border-color:#c0415a;color:#c0415a;}
    .btn-wishlist.active{border-color:#c0415a;color:#c0415a;background:#fce8ed;}

    .highlights{background:#fffafb;border:1px solid #f0e6e8;border-radius:10px;padding:18px 20px;margin-bottom:20px;}
    .highlight-item{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:13px;color:#555;}
    .highlight-item:last-child{margin-bottom:0;}
    .highlight-dot{width:6px;height:6px;border-radius:50%;background:#c0415a;margin-top:6px;flex-shrink:0;}

    .sold-out-banner{background:#fce8e8;border:1px solid #f0c0c0;border-radius:8px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:10px;font-size:13px;color:#c03030;}

    /* ── Rating breakdown ── */
    .breakdown-row{display:flex;align-items:center;gap:10px;margin-bottom:6px;}
    .breakdown-label{font-size:12px;color:#888;width:32px;text-align:right;flex-shrink:0;}
    .breakdown-bar-wrap{flex:1;height:8px;background:#f0e6e8;border-radius:4px;overflow:hidden;}
    .breakdown-bar{height:100%;background:#c0415a;border-radius:4px;transition:width .4s ease;}
    .breakdown-count{font-size:11px;color:#aaa;width:24px;text-align:left;flex-shrink:0;}

    /* ── Review section ── */
    .review-section{padding:48px 48px 0;}
    .section-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#1a1a2e;margin-bottom:24px;}
    .review-summary{display:flex;gap:40px;align-items:flex-start;margin-bottom:36px;flex-wrap:wrap;}
    .avg-score{text-align:center;}
    .avg-num{font-size:52px;font-weight:700;color:#1a1a2e;line-height:1;}
    .avg-stars{display:flex;justify-content:center;gap:3px;margin:6px 0;}
    .avg-out{font-size:12px;color:#aaa;}

    .review-form{background:#fffafb;border:1px solid #f0e6e8;border-radius:12px;padding:24px;margin-bottom:36px;}
    .review-form h4{font-size:14px;font-weight:600;color:#1a1a2e;margin-bottom:16px;}
    .star-picker{display:flex;gap:6px;margin-bottom:16px;flex-direction:row-reverse;justify-content:flex-end;}
    .star-picker input{display:none;}
    .star-picker label{font-size:28px;color:#ddd;cursor:pointer;transition:color .15s;}
    .star-picker input:checked ~ label,
    .star-picker label:hover,
    .star-picker label:hover ~ label{color:#e8a826;}
    .form-group{margin-bottom:14px;}
    .form-group label{display:block;font-size:12px;color:#888;margin-bottom:5px;font-weight:500;}
    .form-group input,
    .form-group textarea{width:100%;padding:10px 12px;border:1px solid #e8d8dc;border-radius:6px;font-size:13px;font-family:'Poppins',sans-serif;color:#333;resize:vertical;outline:none;transition:border-color .2s;}
    .form-group input:focus,
    .form-group textarea:focus{border-color:#c0415a;}
    .btn-submit-review{padding:10px 28px;background:#c0415a;color:#fff;border:none;border-radius:4px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:background .2s;}
    .btn-submit-review:hover{background:#a33049;}

    .review-list{display:flex;flex-direction:column;gap:16px;margin-bottom:48px;}
    .review-card{border:1px solid #f0e6e8;border-radius:10px;padding:18px 20px;background:#fff;}
    .review-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:8px;}
    .reviewer-name{font-size:13px;font-weight:600;color:#1a1a2e;}
    .review-date{font-size:11px;color:#aaa;}
    .review-stars{display:flex;gap:2px;margin-bottom:6px;}
    .review-title{font-size:13px;font-weight:500;color:#1a1a2e;margin-bottom:4px;}
    .review-comment{font-size:13px;color:#666;line-height:1.6;}
    .btn-delete-review{background:none;border:none;color:#ccc;font-size:11px;cursor:pointer;transition:color .2s;}
    .btn-delete-review:hover{color:#e05555;}
    .no-reviews{text-align:center;padding:36px;color:#aaa;font-size:13px;}

    /* ── Related products ── */
    .related-section{padding:0 48px 60px;}
    .related-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
    .rel-card{border:1px solid #f0e6e6;border-radius:10px;overflow:hidden;background:#fff;cursor:pointer;transition:all .3s ease;}
    .rel-card:hover{box-shadow:0 10px 30px rgba(0,0,0,0.09);transform:translateY(-3px);}
    .rel-img{height:150px;background:linear-gradient(135deg,#fff5f7,#fce8ed);overflow:hidden;display:flex;align-items:center;justify-content:center;}
    .rel-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
    .rel-card:hover .rel-img img{transform:scale(1.06);}
    .rel-body{padding:12px 14px;}
    .rel-name{font-size:12px;font-weight:500;color:#1a1a2e;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .rel-price{font-size:13px;font-weight:700;color:#c0415a;}
    .rel-orig{font-size:11px;color:#ccc;text-decoration:line-through;margin-left:5px;}
    /* ✅ NEW: save on related cards */
    .rel-save{font-size:10px;color:#22b573;font-weight:600;display:block;margin-top:2px;}

    /* ── Toast ── */
    .toast{position:fixed;bottom:28px;right:28px;padding:12px 22px;border-radius:6px;font-size:13px;font-weight:500;color:#fff;z-index:9999;opacity:0;transform:translateY(10px);transition:all .3s ease;pointer-events:none;}
    .toast.show{opacity:1;transform:translateY(0);}
    .toast.success{background:#22b573;}
    .toast.error{background:#e05555;}

    /* ── Responsive ── */
    @media(max-width:900px){
      .detail-wrap{flex-direction:column;padding:0 20px 40px;gap:28px;}
      .col-images{width:100%;min-width:unset;position:static;}
      .main-img-wrap{height:300px;}
      .related-grid{grid-template-columns:repeat(2,1fr);}
      .review-section,.related-section{padding-left:20px;padding-right:20px;}
      .breadcrumb{padding:14px 20px;}
    }
  </style>
</head>
<body>
  <%- include('../partials/user/header') %>

  <!-- ── Breadcrumb ── -->
  <nav class="breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/products">Shop</a>
    <% if(product.categoryId){ %>
    <span class="breadcrumb-sep">›</span>
    <a href="/products?category=<%= product.categoryId._id %>"><%= product.categoryId.name %></a>
    <% } %>
    <span class="breadcrumb-sep">›</span>
    <span style="color:#555;"><%= product.name %></span>
  </nav>

  <% if(!product.inStock){ %>
  <div class="sold-out-banner" style="margin:0 48px 0;">
    <span style="font-size:18px;">⚠️</span>
    <div>
      <strong>Currently out of stock.</strong>
      <span style="margin-left:6px;">Check back soon or explore similar products below.</span>
    </div>
  </div>
  <% } %>

  <div class="detail-wrap">

    <!-- LEFT — Image gallery -->
    <div class="col-images">
      <div class="shade-gallery-indicator" id="shadeGalleryIndicator">
        <span id="shadeGalleryIndicatorText">Showing images for this shade</span>
      </div>

      <div class="main-img-wrap" id="mainImgWrap" onclick="toggleZoom(this)">
        <% if(product.images && product.images[0]){ %>
          <img id="mainImg" src="<%= product.images[0] %>" alt="<%= product.name %>">
        <% } else { %>
          <div style="display:flex;align-items:center;justify-content:height:100%;font-size:60px;">💄</div>
        <% } %>
        <span class="zoom-hint" id="zoomHint">🔍 Click to zoom</span>
      </div>

      <div class="thumb-row" id="thumbRow">
        <% if(product.images && product.images.length > 0){ %>
          <% product.images.forEach((img, i) => { %>
          <div class="thumb <%= i === 0 ? 'active' : '' %>" onclick="switchMainImage('<%= img %>', this)">
            <img src="<%= img %>" alt="Image <%= i+1 %>">
          </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- RIGHT — Product info -->
    <div class="col-info">
      <p class="prod-brand">Blush Berry</p>
      <h1 class="prod-title"><%= product.name %></h1>
      <% if(product.categoryId){ %>
      <p class="prod-category">Category: <a href="/products?category=<%= product.categoryId._id %>" style="color:#c0415a;"><%= product.categoryId.name %></a></p>
      <% } %>

      <!-- Rating row -->
      <div class="rating-row">
        <div class="stars-display">
          <% for(let i=1; i<=5; i++){ %>
            <span class="star <%= i <= Math.round(avgRating) ? '' : 'empty' %>">★</span>
          <% } %>
        </div>
        <span class="rating-num"><%= avgRating %></span>
        <span class="rating-count">(<%= reviewCount %> review<%= reviewCount !== 1 ? 's' : '' %>)</span>
        <a href="#reviews" style="font-size:12px;color:#c0415a;margin-left:4px;">Write a review</a>
      </div>

      <!-- ✅ Price block: sale price + strikethrough + % tag + save amount -->
      <div class="price-block">
        <div style="display:flex;align-items:baseline;flex-wrap:wrap;gap:4px;">
          <span class="price-main" id="displayPrice">₹<%= product.displayPrice.toFixed(2) %></span>
          <% if(product.displayOffer > 0){ %>
            <span class="price-orig" id="origPrice">₹<%= product.originalPrice.toFixed(2) %></span>
            <span class="offer-tag"><%= product.displayOffer %>% OFF</span>
          <% } %>
        </div>
        <% if(product.displayOffer > 0){ %>
          <p class="price-save" id="priceSave">
            You save ₹<%= (product.originalPrice - product.displayPrice).toFixed(2) %>
          </p>
        <% } %>
        <p class="price-per-shade">Price may vary by shade</p>

        <% if(!product.inStock){ %>
          <span class="stock-status stock-out"><span class="stock-dot"></span> Out of Stock</span>
        <% } else { %>
          <%
            const totalStock = product.variants.reduce((s,v) => s + (v.stock||0), 0)
          %>
          <% if(totalStock <= 10){ %>
            <span class="stock-status stock-low"><span class="stock-dot"></span> Only <%= totalStock %> left!</span>
          <% } else { %>
            <span class="stock-status stock-in"><span class="stock-dot"></span> In Stock</span>
          <% } %>
        <% } %>
      </div>

      <!-- Shade selector -->
      <% if(product.variants && product.variants.length){ %>
      <div style="margin-bottom:20px;">
        <p class="section-label">Select Shade — <span id="selectedShadeName" style="color:#c0415a;text-transform:none;letter-spacing:0;font-weight:600;"><%= product.variants[0].shade %></span></p>
        <div class="shade-selector">
          <% product.variants.forEach((v, i) => { %>
          <div class="shade-btn <%= i===0 ? 'active' : '' %> <%= v.stock===0 ? 'out-of-stock' : '' %>"
               onclick="<%= v.stock > 0 ? `selectShade(this)` : '' %>"
               data-shade="<%= v.shade %>"
               data-sale-price="<%= v.salePrice > 0 ? v.salePrice : v.varientPrice %>"
               data-orig-price="<%= v.varientPrice %>"
               data-stock="<%= v.stock %>"
               data-has-gallery="<%= v.images && v.images.length > 0 ? 'true' : 'false' %>"
               data-images='<%- JSON.stringify(v.images && v.images.length > 0 ? v.images : []) %>'
               title="<%= v.shade %><%= v.stock===0 ? ' (Out of stock)' : '' %>">
            <% if(v.image){ %>
              <img src="<%= v.image %>" class="shade-swatch" alt="<%= v.shade %>">
            <% } else { %>
              <div class="shade-swatch" style="background:#e8b0c0;"></div>
            <% } %>
            <span class="shade-name"><%= v.shade %></span>
            <span class="shade-price">₹<%= (v.salePrice > 0 ? v.salePrice : v.varientPrice).toFixed(2) %></span>
          </div>
          <% }) %>
        </div>
        <p style="font-size:11px;color:#bbb;margin-top:-8px;">
          <span id="shadeStockNote"></span>
        </p>
      </div>
      <% } %>

      <!-- Qty + Cart + Wishlist -->
      <% if(product.inStock){ %>
      <div class="qty-cart-row">
        <div class="qty-wrap">
          <button class="qty-btn" onclick="changeQty(-1)">−</button>
          <input type="number" class="qty-input" id="qtyInput" value="1" min="1" max="99" readonly>
          <button class="qty-btn" onclick="changeQty(1)">+</button>
        </div>
        <button class="btn-add-cart" id="addCartBtn" onclick="addToCart('<%= product._id %>')">
          ADD TO CART
        </button>
        <%
  const isWished = wishlistIds && wishlistIds.includes(String(product._id));
%>
<button class="btn-wishlist <%= isWished ? 'active' : '' %>"
        id="wishBtn"
        onclick="toggleWishlist('<%= product._id %>')">
  <%= isWished ? '♥' : '♡' %>
</button>
      </div>
      <% } else { %>
      <div style="margin-bottom:20px;">
        <button disabled class="btn-add-cart" style="width:100%;opacity:.5;cursor:not-allowed;">OUT OF STOCK</button>
        <p style="font-size:12px;color:#aaa;margin-top:8px;text-align:center;">This product is currently unavailable.</p>
      </div>
      <% } %>

      <!-- Product highlights -->
      <div class="highlights">
        <p class="section-label" style="margin-bottom:12px;">Product Highlights</p>
        <% if(product.description){ %>
          <div class="highlight-item">
            <span class="highlight-dot"></span>
            <span><%= product.description %></span>
          </div>
        <% } %>
        <div class="highlight-item">
          <span class="highlight-dot"></span>
          <span>Long-lasting formula — up to 16 hours of wear</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-dot"></span>
          <span>Dermatologist tested — suitable for sensitive lips</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-dot"></span>
          <span>Available in <%= product.variants.length %> shade<%= product.variants.length !== 1 ? 's' : '' %></span>
        </div>
        <% if(product.displayOffer > 0){ %>
        <div class="highlight-item">
          <span class="highlight-dot"></span>
          <span style="color:#c0415a;font-weight:500;">🏷 <%= product.displayOffer %>% off — limited time offer</span>
        </div>
        <% } %>
      </div>

    </div>
  </div>


  <!-- ══════════════════════════════════════════
       REVIEWS SECTION
  ══════════════════════════════════════════ -->
  <div class="review-section" id="reviews">
    <h2 class="section-title">Customer Reviews</h2>

    <div class="review-summary">
      <div class="avg-score">
        <div class="avg-num"><%= avgRating %></div>
        <div class="avg-stars">
          <% for(let i=1;i<=5;i++){ %>
            <span style="font-size:18px;color:<%= i<=Math.round(avgRating)?'#e8a826':'#ddd' %>">★</span>
          <% } %>
        </div>
        <div class="avg-out">out of 5</div>
        <div style="font-size:12px;color:#aaa;margin-top:4px;"><%= reviewCount %> review<%= reviewCount!==1?'s':'' %></div>
      </div>

      <div style="flex:1;max-width:300px;">
        <% [5,4,3,2,1].forEach(star => { %>
        <div class="breakdown-row">
          <span class="breakdown-label"><%= star %>★</span>
          <div class="breakdown-bar-wrap">
            <div class="breakdown-bar" style="width:<%= reviewCount > 0 ? Math.round((ratingBreakdown[star]/reviewCount)*100) : 0 %>%"></div>
          </div>
          <span class="breakdown-count"><%= ratingBreakdown[star] %></span>
        </div>
        <% }) %>
      </div>
    </div>

    <% if(user){ %>
    <div class="review-form">
      <h4><%= userReview ? 'Update Your Review' : 'Write a Review' %></h4>
      <form id="reviewForm" onsubmit="submitReview(event)">
        <p class="section-label">Your Rating</p>
        <div class="star-picker">
          <% for(let i=5;i>=1;i--){ %>
          <input type="radio" name="rating" id="star<%= i %>" value="<%= i %>"
            <%= userReview && userReview.rating===i ? 'checked' : '' %>>
          <label for="star<%= i %>">★</label>
          <% } %>
        </div>
        <div class="form-group">
          <label>Review Title</label>
          <input type="text" name="title" placeholder="Sum it up in a few words…" maxlength="100"
                 value="<%= userReview ? userReview.title || '' : '' %>">
        </div>
        <div class="form-group">
          <label>Your Review</label>
          <textarea name="comment" rows="4" placeholder="Tell others what you think about this product…" maxlength="1000"><%= userReview ? userReview.comment || '' : '' %></textarea>
        </div>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
          <button type="submit" class="btn-submit-review">
            <%= userReview ? 'Update Review' : 'Submit Review' %>
          </button>
          <% if(userReview){ %>
          <button type="button" class="btn-delete-review" onclick="deleteReview()" style="font-size:12px;padding:8px 16px;border:1px solid #f0e6e8;border-radius:4px;color:#aaa;">
            Delete My Review
          </button>
          <% } %>
        </div>
      </form>
    </div>
    <% } else { %>
    <div style="background:#fffafb;border:1px solid #f0e6e8;border-radius:10px;padding:20px;margin-bottom:28px;text-align:center;font-size:13px;color:#888;">
      <a href="/login" style="color:#c0415a;font-weight:600;">Log in</a> to leave a review.
    </div>
    <% } %>

    <div class="review-list" id="reviewList">
      <% if(reviews.length === 0){ %>
        <div class="no-reviews">💄 No reviews yet — be the first to share your thoughts!</div>
      <% } %>
      <% reviews.forEach(r => { %>
      <div class="review-card" id="review-<%= r._id %>">
        <div class="review-header">
          <div>
            <span class="reviewer-name"><%= r.userId?.fullName || 'Anonymous' %></span>
            <span class="review-date" style="margin-left:10px;"><%= new Date(r.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
          </div>
          <% if(user && String(r.userId?._id) === String(user._id)){ %>
          <button class="btn-delete-review" onclick="deleteReview()">Delete</button>
          <% } %>
        </div>
        <div class="review-stars">
          <% for(let i=1;i<=5;i++){ %>
            <span style="font-size:14px;color:<%= i<=r.rating?'#e8a826':'#ddd' %>">★</span>
          <% } %>
        </div>
        <% if(r.title){ %><p class="review-title"><%= r.title %></p><% } %>
        <% if(r.comment){ %><p class="review-comment"><%= r.comment %></p><% } %>
      </div>
      <% }) %>
    </div>
  </div>


  <!-- ══════════════════════════════════════════
       RELATED PRODUCTS
  ══════════════════════════════════════════ -->
  <% if(related && related.length){ %>
  <div class="related-section">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:24px;">
      <div>
        <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#c0415a;margin-bottom:6px;">You May Also Like</p>
        <h2 style="font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#1a1a2e;">Related Products</h2>
      </div>
      <a href="/products?category=<%= product.categoryId?._id %>" style="font-size:12px;color:#c0415a;border-bottom:1px solid #c0415a;padding-bottom:2px;">View All →</a>
    </div>
    <div class="related-grid">
      <% related.forEach(rel => { %>
      <div class="rel-card" onclick="window.location='/products/<%= rel._id %>'">
        <div class="rel-img">
          <% if(rel.images && rel.images[0]){ %>
            <img src="<%= rel.images[0] %>" alt="<%= rel.name %>">
          <% } else { %>
            <span style="font-size:32px;">💄</span>
          <% } %>
        </div>
        <div class="rel-body">
          <p class="rel-name" title="<%= rel.name %>"><%= rel.name %></p>
          <!-- Related card: sale price + strikethrough + save -->
          <div style="display:flex;align-items:baseline;gap:5px;flex-wrap:wrap;">
            <span class="rel-price">₹<%= rel.displayPrice.toFixed(2) %></span>
            <% if(rel.displayOffer > 0){ %>
              <span class="rel-orig">₹<%= rel.originalPrice.toFixed(2) %></span>
            <% } %>
          </div>
          <% if(rel.displayOffer > 0){ %>
            <span class="rel-save">Save ₹<%= (rel.originalPrice - rel.displayPrice).toFixed(2) %></span>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <div class="toast" id="toast"></div>

  <%- include('../partials/user/footer') %>

  <script>
    const PRODUCT_ID   = '<%= product._id %>'
    const DEFAULT_IMGS = <%- JSON.stringify(product.images || []) %>

    // ── Toast ──
    function showToast(msg, type='success') {
      const t = document.getElementById('toast')
      t.textContent = msg
      t.className   = `toast ${type} show`
      setTimeout(() => t.classList.remove('show'), 3000)
    }

    // ── Image zoom ──
    function toggleZoom(wrap) {
      wrap.classList.toggle('zoomed')
      document.getElementById('zoomHint').style.opacity =
        wrap.classList.contains('zoomed') ? '0' : '1'
    }

    document.getElementById('mainImgWrap').addEventListener('mousemove', function(e) {
      if (!this.classList.contains('zoomed')) return
      const rect = this.getBoundingClientRect()
      const x = ((e.clientX - rect.left) / rect.width)  * 100
      const y = ((e.clientY - rect.top)  / rect.height) * 100
      this.querySelector('img').style.transformOrigin = `${x}% ${y}%`
    })

    // ── Switch main image ──
    function switchMainImage(src, thumb) {
      const mainImg = document.getElementById('mainImg')
      if (!mainImg) return
      const wrap = document.getElementById('mainImgWrap')
      wrap.classList.add('fading')
      setTimeout(() => {
        mainImg.src = src
        wrap.classList.remove('fading')
        wrap.classList.remove('zoomed')
      }, 150)
      document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'))
      if (thumb) thumb.classList.add('active')
    }

    // ── Switch gallery ──
    function switchGallery(images) {
      if (!images || images.length === 0) return
      const thumbRow = document.getElementById('thumbRow')
      const mainImg  = document.getElementById('mainImg')
      const wrap     = document.getElementById('mainImgWrap')
      if (!mainImg || !thumbRow) return
      wrap.classList.add('fading')
      setTimeout(() => {
        mainImg.src = images[0]
        wrap.classList.remove('fading')
        wrap.classList.remove('zoomed')
      }, 150)
      thumbRow.innerHTML = ''
      images.forEach((src, i) => {
        const div = document.createElement('div')
        div.className = 'thumb' + (i === 0 ? ' active' : '')
        div.onclick = () => switchMainImage(src, div)
        const img = document.createElement('img')
        img.src = src
        img.alt = 'Shade image ' + (i + 1)
        div.appendChild(img)
        thumbRow.appendChild(div)
      })
    }

    // ── Shade selector ──
    function selectShade(el) {
      document.querySelectorAll('.shade-btn').forEach(b => b.classList.remove('active'))
      el.classList.add('active')

      const name      = el.dataset.shade
      const salePrice = parseFloat(el.dataset.salePrice)
      const origPrice = parseFloat(el.dataset.origPrice)
      const stock     = parseInt(el.dataset.stock)
      const hasGallery = el.dataset.hasGallery === 'true'
      let shadeImgs = []
      if (hasGallery) {
        try { shadeImgs = JSON.parse(el.dataset.images || '[]') }
        catch(e) { shadeImgs = [] }
      }

      // update shade name
      document.getElementById('selectedShadeName').textContent = name

      // update price display
      document.getElementById('displayPrice').textContent = '₹' + salePrice.toFixed(2)
      const origEl = document.getElementById('origPrice')
      if (origEl) origEl.textContent = '₹' + origPrice.toFixed(2)

      // ✅ update save amount dynamically when shade changes
      const saveEl = document.getElementById('priceSave')
      if (saveEl) {
        const saved = origPrice - salePrice
        if (saved > 0) {
          saveEl.textContent = 'You save ₹' + saved.toFixed(2)
          saveEl.style.display = 'block'
        } else {
          saveEl.style.display = 'none'
        }
      }

      // update stock note
      const note = document.getElementById('shadeStockNote')
      if (stock <= 5 && stock > 0) {
        note.textContent = `⚠ Only ${stock} left in this shade`
        note.style.color = '#e8a826'
      } else {
        note.textContent = ''
      }

      // update qty max
      const qtyInput = document.getElementById('qtyInput')
      if (qtyInput) qtyInput.max = stock

      // switch gallery
      const indicator     = document.getElementById('shadeGalleryIndicator')
      const indicatorText = document.getElementById('shadeGalleryIndicatorText')
      if (hasGallery && shadeImgs.length > 0) {
        switchGallery(shadeImgs)
        if (indicator) {
          indicator.classList.add('visible')
          indicatorText.textContent = 'Showing images for ' + name
        }
      } else {
        switchGallery(DEFAULT_IMGS)
        if (indicator) indicator.classList.remove('visible')
      }
    }

    // ── Quantity ──
    function changeQty(delta) {
      const input = document.getElementById('qtyInput')
      if (!input) return
      const max = parseInt(input.max) || 99
      let val   = parseInt(input.value) + delta
      val = Math.max(1, Math.min(val, max))
      input.value = val
    }

    // ── Add to cart ──
    function addToCart(productId) {
      const btn   = document.getElementById('addCartBtn')
      const qty   = parseInt(document.getElementById('qtyInput')?.value) || 1
      const shade = document.getElementById('selectedShadeName')?.textContent || ''
      btn.textContent = 'Adding…'
      btn.disabled    = true

      fetch('/cart/add', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ productId, quantity: qty, shade })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('Added to cart! 🛍')
          btn.textContent      = '✓ Added'
          btn.style.background = '#22b573'
          const badge = document.getElementById('cartCount')
          if (badge && data.cartCount) badge.textContent = data.cartCount
          setTimeout(() => {
            btn.textContent      = 'ADD TO CART'
            btn.style.background = ''
            btn.disabled         = false
          }, 2000)
        } else {
          showToast(data.message || 'Could not add to cart', 'error')
          btn.textContent = 'ADD TO CART'
          btn.disabled    = false
          if (data.redirect) window.location.href = data.redirect
        }
      })
      .catch(() => {
        showToast('Something went wrong', 'error')
        btn.textContent = 'ADD TO CART'
        btn.disabled    = false
      })
    }

    // ── Wishlist ──
    function toggleWishlist(productId) {
      const btn = document.getElementById('wishBtn')
      btn.classList.toggle('active')
      btn.textContent = btn.classList.contains('active') ? '♥' : '♡'

      fetch('/wishlist/toggle', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ productId })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast(btn.classList.contains('active') ? 'Added to wishlist ♥' : 'Removed from wishlist')
        } else {
          btn.classList.toggle('active')
          btn.textContent = btn.classList.contains('active') ? '♥' : '♡'
          if (data.redirect) window.location.href = data.redirect
        }
      })
      .catch(() => {
        btn.classList.toggle('active')
        btn.textContent = btn.classList.contains('active') ? '♥' : '♡'
      })
    }

    // ── Submit review ──
    function submitReview(e) {
      e.preventDefault()
      const form    = document.getElementById('reviewForm')
      const rating  = form.querySelector('input[name="rating"]:checked')?.value
      if (!rating) { showToast('Please select a star rating', 'error'); return }
      const title   = form.querySelector('input[name="title"]').value.trim()
      const comment = form.querySelector('textarea[name="comment"]').value.trim()

      fetch(`/products/${PRODUCT_ID}/review`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ rating, title, comment })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast(data.message)
          setTimeout(() => location.reload(), 1200)
        } else {
          showToast(data.message || 'Could not submit review', 'error')
        }
      })
      .catch(() => showToast('Something went wrong', 'error'))
    }

    // ── Delete review ──
    function deleteReview() {
      if (!confirm('Delete your review?')) return
      fetch(`/products/${PRODUCT_ID}/review`, {
        method:  'DELETE',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showToast('Review deleted')
          setTimeout(() => location.reload(), 1000)
        } else {
          showToast(data.message || 'Could not delete', 'error')
        }
      })
      .catch(() => showToast('Something went wrong', 'error'))
    }

    // ── Init ──
    window.addEventListener('DOMContentLoaded', () => {
      const msg = '<%= typeof sessionToast !== "undefined" ? sessionToast : "" %>'
      if (msg) showToast(msg, 'error')
      const firstActive = document.querySelector('.shade-btn.active')
      if (firstActive) selectShade(firstActive)
    })
  </script>
</body>
</html>
