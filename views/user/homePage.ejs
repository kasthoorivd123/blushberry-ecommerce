    <div style="position:absolute;right:-100px;top:-100px;width:480px;height:480px;background:radial-gradient(circle,#f9d5de 0%,transparent 65%);border-radius:50%;z-index:1;"></div>
    <div style="position:absolute;right:200px;bottom:-60px;width:200px;height:200px;background:radial-gradient(circle,#fce8ed 0%,transparent 70%);border-radius:50%;z-index:1;"></div>

    <div style="position:absolute;right:80px;top:50%;transform:translateY(-50%);display:flex;gap:14px;align-items:flex-end;z-index:3;">
      <div style="display:flex;flex-direction:column;align-items:center;gap:0;">
        <div style="width:16px;height:12px;background:#d64d6a;clip-path:polygon(20% 0%,80% 0%,100% 100%,0% 100%);border-radius:2px 2px 0 0;"></div>
        <div style="width:20px;height:130px;background:linear-gradient(180deg,#e06080 0%,#8b1a2f 100%);border-radius:2px 2px 0 0;"></div>
        <div style="width:24px;height:18px;background:#c8bfc2;border-radius:0 0 3px 3px;"></div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:0;margin-bottom:30px;">
        <div style="width:16px;height:12px;background:#e8756a;clip-path:polygon(20% 0%,80% 0%,100% 100%,0% 100%);border-radius:2px 2px 0 0;"></div>
        <div style="width:20px;height:160px;background:linear-gradient(180deg,#e8908a 0%,#a03020 100%);border-radius:2px 2px 0 0;"></div>
        <div style="width:24px;height:18px;background:#d4c0c0;border-radius:0 0 3px 3px;"></div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:0;margin-bottom:10px;">
        <div style="width:16px;height:12px;background:#c98fa0;clip-path:polygon(20% 0%,80% 0%,100% 100%,0% 100%);border-radius:2px 2px 0 0;"></div>
        <div style="width:20px;height:105px;background:linear-gradient(180deg,#d4a0b4 0%,#7a3a50 100%);border-radius:2px 2px 0 0;"></div>
        <div style="width:24px;height:18px;background:#c8b8bc;border-radius:0 0 3px 3px;"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SHADE SELECTOR
  ═══════════════════════════════════════════════════ -->
  <section style="padding:64px 48px;background:#fff;" id="shades">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;">
      <div>
        <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#c0415a;margin-bottom:8px;">Handpicked For You</p>
        <h2 style="font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:#1a1a2e;">Find Your Perfect Shade</h2>
      </div>
      <a href="/products" style="font-size:12px;color:#c0415a;font-weight:500;border-bottom:1px solid #c0415a;padding-bottom:2px;">View All →</a>
    </div>

    <div style="display:flex;gap:28px;flex-wrap:wrap;">
      <div class="shade-card" style="flex:1;min-width:200px;background:#fffafb;border:1px solid #f5e8ec;border-radius:12px;padding:32px 24px;text-align:center;cursor:pointer;transition:all 0.3s ease;">
        <div style="position:relative;width:90px;height:90px;margin:0 auto 20px;">
          <div style="width:90px;height:90px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#e8b08a,#c8956c);box-shadow:0 10px 30px rgba(200,149,108,0.4);"></div>
        </div>
        <h3 style="font-family:'Playfair Display',serif;font-size:19px;font-weight:700;color:#1a1a2e;margin-bottom:6px;">Matte</h3>
        <p style="font-size:12px;color:#bbb;margin-bottom:6px;">Warm Golden Nude</p>
        <div style="display:flex;justify-content:center;gap:5px;margin-bottom:18px;">
          <div style="width:14px;height:14px;border-radius:50%;background:#c8956c;border:1px solid #eee;"></div>
          <div style="width:14px;height:14px;border-radius:50%;background:#d4a87c;border:1px solid #eee;"></div>
          <div style="width:14px;height:14px;border-radius:50%;background:#b87a52;border:1px solid #eee;"></div>
        </div>
        <a href="/products" style="font-size:11px;color:#c0415a;font-weight:600;letter-spacing:0.8px;border-bottom:1px solid #c0415a;text-transform:uppercase;">Shop →</a>
      </div>

      <div class="shade-card" style="flex:1;min-width:200px;background:#fffafb;border:1px solid #f5e8ec;border-radius:12px;padding:32px 24px;text-align:center;cursor:pointer;transition:all 0.3s ease;">
        <div style="width:90px;height:90px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#d4668e,#b5446e);box-shadow:0 10px 30px rgba(181,68,110,0.4);margin:0 auto 20px;"></div>
        <h3 style="font-family:'Playfair Display',serif;font-size:19px;font-weight:700;color:#1a1a2e;margin-bottom:6px;">Satin</h3>
        <p style="font-size:12px;color:#bbb;margin-bottom:6px;">Deep Berry Pink</p>
        <div style="display:flex;justify-content:center;gap:5px;margin-bottom:18px;">
          <div style="width:14px;height:14px;border-radius:50%;background:#b5446e;border:1px solid #eee;"></div>
          <div style="width:14px;height:14px;border-radius:50%;background:#c75a80;border:1px solid #eee;"></div>
          <div style="width:14px;height:14px;border-radius:50%;background:#982a58;border:1px solid #eee;"></div>
        </div>
        <a href="/products" style="font-size:11px;color:#c0415a;font-weight:600;letter-spacing:0.8px;border-bottom:1px solid #c0415a;text-transform:uppercase;">Shop →</a>
      </div>

      <div class="shade-card" style="flex:1;min-width:200px;background:#fffafb;border:1px solid #f5e8ec;border-radius:12px;padding:32px 24px;text-align:center;cursor:pointer;transition:all 0.3s ease;">
        <div style="width:90px;height:90px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#fcc8d4,#f4a0b0);box-shadow:0 10px 30px rgba(244,160,176,0.45);margin:0 auto 20px;"></div>
        <h3 style="font-family:'Playfair Display',serif;font-size:19px;font-weight:700;color:#1a1a2e;margin-bottom:6px;">Glossy</h3>
        <p style="font-size:12px;color:#bbb;margin-bottom:6px;">Sheer Baby Pink</p>
        <div style="display:flex;justify-content:center;gap:5px;margin-bottom:18px;">
          <div style="width:14px;height:14px;border-radius:50%;background:#f4a0b0;border:1px solid #eee;"></div>
          <div style="width:14px;height:14px;border-radius:50%;background:#f8bcc8;border:1px solid #eee;"></div>
          <div style="width:14px;height:14px;border-radius:50%;background:#e88098;border:1px solid #eee;"></div>
        </div>
        <a href="/products" style="font-size:11px;color:#c0415a;font-weight:600;letter-spacing:0.8px;border-bottom:1px solid #c0415a;text-transform:uppercase;">Shop →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       MAYBELLINE PROMO BANNER
  ═══════════════════════════════════════════════════ -->
  <section style="margin:0 48px 64px;border-radius:16px;background:linear-gradient(135deg,#14122a 0%,#2a1535 50%,#1a1a3e 100%);padding:56px 56px;display:flex;align-items:center;justify-content:space-between;overflow:hidden;position:relative;">
    <div style="position:absolute;right:-80px;top:-80px;width:360px;height:360px;border:1.5px solid rgba(255,255,255,0.06);border-radius:50%;"></div>
    <div style="position:absolute;right:-20px;top:-20px;width:240px;height:240px;border:1.5px solid rgba(255,255,255,0.04);border-radius:50%;"></div>
    <div style="position:absolute;left:45%;bottom:-40px;width:180px;height:180px;background:rgba(232,117,106,0.08);border-radius:50%;filter:blur(20px);"></div>

    <div style="position:relative;z-index:2;">
      <p style="font-size:10px;letter-spacing:5px;text-transform:uppercase;color:#f4a0b0;margin-bottom:10px;font-weight:500;">MAYBELLINE NEW YORK</p>
      <h2 style="font-family:'Playfair Display',serif;font-size:62px;font-weight:900;color:#fff;line-height:1.05;margin-bottom:14px;">
        LIPSTICK<br/>
        <span style="color:#e8756a;font-style:italic;">DAY</span>
      </h2>
      <p style="color:#aaa;font-size:13px;margin-bottom:28px;max-width:300px;">Celebrate bold beauty with exclusive one-day deals. Limited stock — shop before it runs out.</p>
      <a href="/products" style="display:inline-block;background:#e8756a;color:#fff;padding:14px 36px;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;border-radius:3px;transition:background 0.2s;">SHOP NOW</a>
    </div>

    <div style="position:relative;z-index:2;text-align:center;">
      <div style="width:130px;height:130px;border-radius:50%;border:2px solid rgba(232,117,106,0.4);display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(232,117,106,0.08);">
        <span style="font-family:'Playfair Display',serif;font-size:40px;font-weight:900;color:#e8756a;line-height:1;">50%</span>
        <span style="font-size:11px;letter-spacing:3px;color:#f4a0b0;text-transform:uppercase;">OFF</span>
      </div>
      <p style="color:#888;font-size:11px;margin-top:12px;letter-spacing:1px;">Today Only</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       PRODUCTS GRID
  ═══════════════════════════════════════════════════ -->
  <section style="padding:0 48px 72px;" id="shop">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;">
      <div>
        <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#c0415a;margin-bottom:8px;">Trending Now</p>
        <h2 style="font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:#1a1a2e;">Bestsellers</h2>
      </div>
      <a href="/products" style="font-size:12px;color:#c0415a;font-weight:500;border-bottom:1px solid #c0415a;padding-bottom:2px;">View All Products →</a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:22px;">
      <% products.forEach(product => { %>
      <div class="product-card"
           style="border:1px solid #f0e6e6;border-radius:10px;overflow:hidden;background:#fff;transition:all 0.3s ease;cursor:pointer;"
           onclick="window.location='/products/<%= product._id %>'">

        <!-- Image area -->
        <div style="height:168px;background:linear-gradient(135deg,#fff5f7,#fce8ed);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">

          <% if(product.images && product.images[0]){ %>
            <img src="<%= product.images[0] %>"
                 alt="<%= product.name %>"
                 style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;">
          <% } else { %>
            <span style="font-size:36px;">💄</span>
          <% } %>

          <!-- ✅ UPDATED BADGE: shows % off instead of generic "SALE" -->
          <% if(!product.inStock){ %>
            <span style="position:absolute;top:10px;right:10px;background:#999;color:#fff;font-size:9px;padding:3px 8px;border-radius:20px;font-weight:600;letter-spacing:0.5px;">SOLD OUT</span>
          <% } else if(product.displayOffer >= 10){ %>
            <span style="position:absolute;top:10px;right:10px;background:#22b573;color:#fff;font-size:9px;padding:3px 8px;border-radius:20px;font-weight:600;letter-spacing:0.5px;"><%= product.displayOffer %>% OFF</span>
          <% } else if((Date.now() - new Date(product.createdAt)) < 7*24*60*60*1000){ %>
            <span style="position:absolute;top:10px;right:10px;background:#c0415a;color:#fff;font-size:9px;padding:3px 8px;border-radius:20px;font-weight:600;letter-spacing:0.5px;">NEW</span>
          <% } %>

          <!-- Wishlist button -->
<%
  const isWished = Array.isArray(wishlistIds) && wishlistIds.includes(String(product._id));
%>
<button
  onclick="toggleWishlist(event, '<%= product._id %>')"
  class="wish-icon-btn <%= isWished ? 'active' : '' %>"
  style="
    position:absolute;top:10px;left:10px;
    background:#fff;
    border-radius:50%;width:28px;height:28px;
    font-size:14px;cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    transition:all .2s;
  ">
  <%= isWished ? '♥' : '♡' %>
</button>
<button
  onclick="toggleWishlist(event, '<%= product._id %>')"
  class="wish-icon-btn <%= isWished ? 'active' : '' %>"
  style="
    position:absolute;top:10px;left:10px;
    background:#fff;
    border:1px solid #f0e6e6;
    border-radius:50%;width:28px;height:28px;
    font-size:14px;cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    transition:all .2s;
  ">
  <%= isWished ? '♥' : '♡' %>
</button>
        </div>

        <!-- Card body -->
        <div style="padding:16px;">
          <p style="font-size:9px;color:#bbb;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px;">Blush Berry</p>
          <h4 style="font-size:13px;font-weight:500;color:#1a1a2e;margin-bottom:10px;line-height:1.4;
                     white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"
              title="<%= product.name %>"><%= product.name %></h4>

          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">

            <!-- ✅ UPDATED PRICE BLOCK: shows sale price + strikethrough + save amount -->
            <div>
              <div style="display:flex;align-items:baseline;gap:6px;flex-wrap:wrap;">
                <span style="font-weight:700;color:#c0415a;font-size:15px;">₹<%= product.displayPrice.toFixed(2) %></span>
                <% if(product.displayOffer > 0){ %>
                  <span style="color:#ccc;font-size:11px;text-decoration:line-through;">₹<%= (product.originalPrice || 0).toFixed(2) %></span>
                <% } %>
              </div>
              <% if(product.displayOffer > 0){ %>
                <span style="font-size:10px;color:#22b573;font-weight:600;">
                  Save ₹<%= (product.originalPrice - product.displayPrice).toFixed(2) %>
                </span>
              <% } %>
            </div>

            <% if(product.inStock){ %>
            <button class="btn-cart"
                    onclick="addToCart(event, '<%= product._id %>')"
                    style="background:#1a1a2e;color:#fff;border:none;padding:8px 14px;font-size:10px;cursor:pointer;border-radius:4px;font-weight:500;letter-spacing:0.5px;transition:background 0.2s;white-space:nowrap;">
              ADD TO CART
            </button>
            <% } else { %>
            <button disabled
                    style="background:#ccc;color:#fff;border:none;padding:8px 14px;font-size:10px;border-radius:4px;cursor:not-allowed;white-space:nowrap;">
              OUT OF STOCK
            </button>
            <% } %>
          </div>
        </div>

      </div>
      <% }) %>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       FEATURES STRIP
  ═══════════════════════════════════════════════════ -->
  <section style="background:#1a1a2e;padding:36px 48px;">
    <div style="display:flex;justify-content:space-around;align-items:center;flex-wrap:wrap;gap:24px;">

      <div style="display:flex;align-items:center;gap:18px;color:#fff;">
        <div style="width:48px;height:48px;background:rgba(192,65,90,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;">🚀</div>
        <div>
          <p style="font-size:13px;font-weight:600;margin-bottom:3px;letter-spacing:0.3px;">Express Shipping</p>
          <p style="font-size:12px;color:#888;">Ships within 24 hours</p>
        </div>
      </div>

      <div style="width:1px;height:40px;background:rgba(255,255,255,0.08);"></div>

      <div style="display:flex;align-items:center;gap:18px;color:#fff;">
        <div style="width:48px;height:48px;background:rgba(192,65,90,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;">📦</div>
        <div>
          <p style="font-size:13px;font-weight:600;margin-bottom:3px;letter-spacing:0.3px;">Earning Tracking</p>
          <p style="font-size:12px;color:#888;">Track your order live</p>
        </div>
      </div>

      <div style="width:1px;height:40px;background:rgba(255,255,255,0.08);"></div>

      <div style="display:flex;align-items:center;gap:18px;color:#fff;">
        <div style="width:48px;height:48px;background:rgba(192,65,90,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;">↩️</div>
        <div>
          <p style="font-size:13px;font-weight:600;margin-bottom:3px;letter-spacing:0.3px;">Easy Returns</p>
          <p style="font-size:12px;color:#888;">30-day return policy</p>
        </div>
      </div>

    </div>
  </section>

  <%- include('../partials/user/footer') %>

  <script>
  function addToCart(event, productId) {
    event.stopPropagation()
    const btn = event.currentTarget
    btn.textContent = 'Adding…'
    btn.disabled    = true

    fetch('/cart/add', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ productId, quantity: 1 })
    })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        btn.textContent      = '✓ Added'
        btn.style.background = '#22b573'
        const badge = document.getElementById('cartCount')
        if (badge && data.cartCount) badge.textContent = data.cartCount
        setTimeout(() => {
          btn.textContent      = 'ADD TO CART'
          btn.style.background = ''
          btn.disabled         = false
        }, 1800)
      } else {
        btn.textContent = 'ADD TO CART'
        btn.disabled    = false
        if (data.redirect) window.location.href = data.redirect
        else alert(data.message || 'Could not add to cart')
      }
    })
    .catch(() => {
      btn.textContent = 'ADD TO CART'
      btn.disabled    = false
    })
  }
function toggleWishlist(event, productId) {
  event.stopPropagation()
  const btn = event.currentTarget

  // Optimistic UI update
  const isNowActive = !btn.classList.contains('active')
  btn.classList.toggle('active')
  btn.textContent = isNowActive ? '♥' : '♡'

  fetch('/wishlist/toggle', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify({ productId })
  })
  .then(r => r.json())
  .then(data => {
    if (!data.success) {
      // Revert on failure
      btn.classList.toggle('active')
      btn.textContent = btn.classList.contains('active') ? '♥' : '♡'
      if (data.redirect) window.location.href = data.redirect
    }
  })
  .catch(() => {
    // Revert on network error
    btn.classList.toggle('active')
    btn.textContent = btn.classList.contains('active') ? '♥' : '♡'
  })
}
  </script>

</body>
</html>
