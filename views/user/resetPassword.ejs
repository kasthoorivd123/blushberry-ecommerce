<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Blush-Berry — Reset Password</title>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Jost', sans-serif;
      background: #fdf6f7;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .page-wrapper {
      width: 100%;
      max-width: 960px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1.5px solid #e8c5cb;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 16px 48px rgba(139,42,58,0.10);
      background: #fff;
    }

    /* LEFT PANEL */
    .left-panel {
      position: relative;
      min-height: 520px;
    }
    .left-panel img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .left-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 55%, rgba(196,89,106,0.15) 100%);
    }

    /* RIGHT PANEL */
    .right-panel {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 52px 48px;
    }

    .brand {
      font-family: 'Dancing Script', cursive;
      font-size: 2.4rem;
      color: #3a1a20;
      margin-bottom: 32px;
    }

    .form-title {
      font-size: 1.05rem;
      font-weight: 600;
      color: #3a1a20;
      margin-bottom: 4px;
      align-self: flex-start;
    }
    .form-subtitle {
      font-size: 0.8rem;
      color: #9b7279;
      font-weight: 300;
      margin-bottom: 26px;
      align-self: flex-start;
    }

    /* FIELD */
    .field {
      width: 100%;
      margin-bottom: 16px;
      position: relative;
    }
    .field label {
      display: block;
      font-size: 0.72rem;
      font-weight: 500;
      color: #9b7279;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .field input {
      width: 100%;
      padding: 12px 42px 12px 16px;
      border: 1.5px solid #e8c5cb;
      border-radius: 10px;
      background: #fce8ec;
      font-family: 'Jost', sans-serif;
      font-size: 0.9rem;
      color: #3a1a20;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .field input::placeholder { color: #c8a5ab; }
    .field input:focus {
      border-color: #f2a7b3;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(242,167,179,0.22);
    }
    .field input.is-error  { border-color: #c4596a; background: #fff0f2; }
    .field input.is-success { border-color: #7baa88; }

    .field-error {
      font-size: 0.73rem;
      color: #c4596a;
      margin-top: 5px;
      min-height: 16px;
    }

    /* Eye toggle */
    .eye-btn {
      position: absolute;
      right: 13px;
      top: 36px;
      background: none;
      border: none;
      cursor: pointer;
      color: #9b7279;
      display: flex;
      align-items: center;
      padding: 2px;
      transition: color 0.2s;
    }
    .eye-btn:hover { color: #c4596a; }

    /* Strength bar */
    .strength-bar {
      height: 4px;
      border-radius: 999px;
      background: #e8c5cb;
      margin-top: 8px;
      overflow: hidden;
    }
    .strength-fill {
      height: 100%;
      border-radius: 999px;
      width: 0%;
      transition: width 0.3s, background 0.3s;
    }
    .strength-label {
      font-size: 0.7rem;
      color: #9b7279;
      margin-top: 3px;
      text-align: right;
    }

    /* Alert */
    .alert {
      width: 100%;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 0.8rem;
      margin-bottom: 14px;
      display: none;
    }
    .alert.show   { display: block; }
    .alert.error  { background: #fff0f2; color: #c4596a; border: 1px solid #f5c0ca; }
    .alert.success{ background: #eef6f0; color: #4a8a57; border: 1px solid #b8ddc0; }

    /* BUTTON */
    .btn-primary {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #f2a7b3 0%, #c4596a 100%);
      color: #fff;
      font-family: 'Jost', sans-serif;
      font-size: 0.88rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      margin-top: 8px;
      box-shadow: 0 4px 18px rgba(196,89,106,0.28);
      transition: opacity 0.2s, transform 0.15s;
    }
    .btn-primary:hover   { opacity: 0.92; transform: translateY(-1px); }
    .btn-primary:active  { transform: translateY(0); }
    .btn-primary:disabled{ opacity: 0.55; cursor: not-allowed; transform: none; }
     .wish-btn.active { color: #c0415a; border-color: #c0415a; }
    .btn-primary .spinner {
      display: inline-block;
      width: 15px; height: 15px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
      margin-right: 6px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .back-link {
      margin-top: 16px;
      font-size: 0.78rem;
      color: #9b7279;
      text-align: center;
    }
    .back-link a { color: #c4596a; text-decoration: underline; }
  </style>
</head>
<body>

<div class="page-wrapper">

  <!-- LEFT IMAGE -->
  <div class="left-panel">
    <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=700&q=80" alt="Blush Berry"/>
    <div class="left-overlay"></div>
  </div>

  <!-- RIGHT FORM -->
  <div class="right-panel">

    <div class="brand">Blush-Berry</div>

    <div class="form-title">reset password</div>
    <div class="form-subtitle">Please enter your new password</div>

    <div class="alert" id="alertBox"></div>

    <!-- New Password -->
    <div class="field">
      <label>new password</label>
      <input type="password" id="newPass" placeholder="new password" oninput="checkStrength()" />
      <button type="button" class="eye-btn" onclick="toggleEye('newPass', this)">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
      <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
      <div class="strength-label" id="strengthLabel"></div>
      <div class="field-error" id="newPassError"></div>
    </div>

    <!-- Confirm Password -->
    <div class="field">
      <label>confirm password</label>
      <input type="password" id="confirmPass" placeholder="confirm password" />
      <button type="button" class="eye-btn" onclick="toggleEye('confirmPass', this)">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
      <div class="field-error" id="confirmPassError"></div>
    </div>

    <button class="btn-primary" id="resetBtn" onclick="handleReset()">Reset Password</button>

    <div class="back-link"><a href="/login">Back to login</a></div>

  </div>
</div>

<script>
  /* ── Strength meter ── */
  function checkStrength() {
    const val = document.getElementById('newPass').value;
    const fill = document.getElementById('strengthFill');
    const label = document.getElementById('strengthLabel');
    let score = 0;
    if (val.length >= 8)        score++;
    if (/[A-Z]/.test(val))      score++;
    if (/[0-9]/.test(val))      score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const levels = [
      { pct: '0%',   color: 'transparent', text: '' },
      { pct: '25%',  color: '#e07b7b',     text: 'Weak' },
      { pct: '50%',  color: '#e0a87b',     text: 'Fair' },
      { pct: '75%',  color: '#d4c07b',     text: 'Good' },
      { pct: '100%', color: '#7baa88',     text: 'Strong' },
    ];
    const lvl = levels[score];
    fill.style.width     = lvl.pct;
    fill.style.background = lvl.color;
    label.textContent    = lvl.text;
    label.style.color    = lvl.color;
  }

  /* ── Eye toggle ── */
  function toggleEye(id, btn) {
    const inp = document.getElementById(id);
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    btn.innerHTML = show
      ? `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`
      : `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
  }

  /* ── Alert ── */
  function showAlert(msg, type = 'error') {
    const el = document.getElementById('alertBox');
    el.textContent = msg;
    el.className = `alert ${type} show`;
  }
  function clearAlert() {
    document.getElementById('alertBox').className = 'alert';
  }

  /* ── Submit ── */
  async function handleReset() {
    clearAlert();

    const newPass     = document.getElementById('newPass').value;
    const confirmPass = document.getElementById('confirmPass').value;
    const newInput    = document.getElementById('newPass');
    const confInput   = document.getElementById('confirmPass');
    const newErr      = document.getElementById('newPassError');
    const confErr     = document.getElementById('confirmPassError');

    let valid = true;

    if (!newPass) {
      newErr.textContent = 'Password is required.';
      newInput.classList.add('is-error'); valid = false;
    } else if (newPass.length < 8) {
      newErr.textContent = 'At least 8 characters required.';
      newInput.classList.add('is-error'); valid = false;
    } else {
      newErr.textContent = '';
      newInput.classList.remove('is-error');
      newInput.classList.add('is-success');
    }

    if (!confirmPass) {
      confErr.textContent = 'Please confirm your password.';
      confInput.classList.add('is-error'); valid = false;
    } else if (newPass !== confirmPass) {
      confErr.textContent = 'Passwords do not match.';
      confInput.classList.add('is-error'); valid = false;
    } else {
      confErr.textContent = '';
      confInput.classList.remove('is-error');
      confInput.classList.add('is-success');
    }

    if (!valid) return;

    const btn = document.getElementById('resetBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Please wait…';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
  password: newPass,
  confirmPassword: confirmPass
})
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || 'Something went wrong.');

      showAlert('Password reset successfully! Redirecting…', 'success');
      setTimeout(() => window.location.href = '/login', 2000);

    } catch (err) {
      showAlert(err.message);
      btn.disabled = false;
      btn.innerHTML = 'Reset Password';
    }
  }
</script>

</body>
</html>
