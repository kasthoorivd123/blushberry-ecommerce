<%- include('../partials/admin/adminSidebar') %>

<div style="padding: 32px 36px; min-height: 100vh; background: #1a1a2e;">

  <!-- Page Title + Add Button -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px;">
    <div>
      <h2 style="font-family:'Poppins',sans-serif; font-size:20px; font-weight:700; color:#fff; margin:0;">Coupon Management</h2>
      <p style="font-family:'Poppins',sans-serif; font-size:13px; color:#aaa; margin:4px 0 0;">Create and manage discount coupons</p>
    </div>
    <button onclick="openModal()" style="background:#c0415a; color:#fff; border:none; padding:10px 22px; border-radius:8px; font-size:13px; font-weight:600; font-family:'Poppins',sans-serif; cursor:pointer; display:flex; align-items:center; gap:8px;">
      <svg width="14" height="14" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Coupon
    </button>
  </div>

  <!-- Coupons Table -->
  <div style="background:#16213e; border-radius:14px; overflow:hidden; border:1px solid #2a2a4a;">

    <!-- Total badge -->
    <div style="padding:16px 24px; border-bottom:1px solid #2a2a4a; display:flex; justify-content:flex-end;">
      <span style="background:#c0415a; color:#fff; font-size:12px; font-weight:600; font-family:'Poppins',sans-serif; padding:4px 14px; border-radius:20px;">
        Total: <%= coupons.length %>
      </span>
    </div>

    <table style="width:100%; border-collapse:collapse;">
      <thead>
        <tr style="border-bottom:1px solid #2a2a4a;">
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">S.NO</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">CODE</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">DISCOUNT</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">MIN ORDER</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">MAX USES</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">USED BY</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">EXPIRES</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">STATUS</th>
          <th style="padding:14px 20px; font-family:'Poppins',sans-serif; font-size:11px; font-weight:600; color:#888; text-align:left; letter-spacing:0.5px;">ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        <% if (coupons.length === 0) { %>
          <tr>
            <td colspan="9" style="padding:40px; text-align:center; font-family:'Poppins',sans-serif; font-size:13px; color:#888;">
              No coupons found. Click "Add Coupon" to create one.
            </td>
          </tr>
        <% } %>
        <% coupons.forEach((coupon, i) => { %>
          <tr style="border-bottom:1px solid #2a2a4a; transition:background 0.2s;" onmouseover="this.style.background='#1e2a4a'" onmouseout="this.style.background='transparent'">
            <td style="padding:16px 20px; font-family:'Poppins',sans-serif; font-size:13px; color:#aaa;"><%= coupons.length - i %></td>
            <td style="padding:16px 20px;">
              <span style="background:#2a1a2e; color:#e8a0b0; font-family:'Poppins',sans-serif; font-size:12px; font-weight:700; padding:5px 12px; border-radius:6px; letter-spacing:1px;">
                <%= coupon.code %>
              </span>
            </td>
           <td style="padding:16px 20px; font-family:'Poppins',sans-serif; font-size:14px; font-weight:700; color:#fff;">
  <% if (coupon.discountType === 'percentage') { %>
    <%= coupon.discountAmount %>%
    <% if (coupon.maxDiscount) { %>
      <span style="font-size:11px; color:#aaa; font-weight:400;"> (max ₹<%= coupon.maxDiscount %>)</span>
    <% } %>
  <% } else { %>
    ₹<%= coupon.discountAmount %>
  <% } %>
</td>
            <td style="padding:16px 20px; font-family:'Poppins',sans-serif; font-size:13px; color:#ccc;">
              <%= coupon.minOrderAmount > 0 ? '₹' + coupon.minOrderAmount : '—' %>
            </td>
            <td style="padding:16px 20px; font-family:'Poppins',sans-serif; font-size:13px; color:#ccc;">
              <%= coupon.maxUses || 'Unlimited' %>
            </td>
            <td style="padding:16px 20px;">
              <span style="background:#0f3460; color:#7eb8f7; font-family:'Poppins',sans-serif; font-size:12px; font-weight:600; padding:4px 12px; border-radius:20px;">
                <%= coupon.usedBy.length %>
              </span>
            </td>
            <td style="padding:16px 20px; font-family:'Poppins',sans-serif; font-size:13px; color:#ccc;">
              <%= coupon.expiresAt ? new Date(coupon.expiresAt).toLocaleDateString('en-IN') : 'Never' %>
            </td>
            <td style="padding:16px 20px;">
              <!-- Toggle -->
              <label style="position:relative; display:inline-block; width:42px; height:22px; cursor:pointer;">
                <input type="checkbox" <%= coupon.isActive ? 'checked' : '' %> onchange="toggleCoupon('<%= coupon._id %>', this)" style="opacity:0; width:0; height:0;">
                <span style="position:absolute; inset:0; background:<%= coupon.isActive ? '#c0415a' : '#444' %>; border-radius:22px; transition:0.3s;">
                  <span style="position:absolute; height:16px; width:16px; left:<%= coupon.isActive ? '22px' : '3px' %>; bottom:3px; background:#fff; border-radius:50%; transition:0.3s;"></span>
                </span>
              </label>
              <span style="font-family:'Poppins',sans-serif; font-size:12px; color:<%= coupon.isActive ? '#c0415a' : '#888' %>; margin-left:8px; font-weight:500;">
                <%= coupon.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td style="padding:16px 20px;">
              <button onclick="deleteCoupon('<%= coupon._id %>')" title="Delete" style="background:#2a1a1e; border:1px solid #5a2a35; color:#e57373; width:32px; height:32px; border-radius:8px; cursor:pointer; display:inline-flex; align-items:center; justify-content:center;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="pagination" style="margin:20px; text-align:center;">
  <% for(let i = 1; i <= totalPages; i++) { %>
    <a href="?page=<%= i %>" 
       style="padding:8px 12px; margin:5px; border:1px solid #ccc; color:white; text-decoration:none; <%= i === currentPage ? 'background:#c0415a;' : '' %>">
       <%= i %>
    </a>
  <% } %>
</div>
  </div>
</div>

<!-- Create Coupon Modal -->
<div id="couponModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:1000; align-items:center; justify-content:center;">
  <div style="background:#16213e; border-radius:14px; padding:32px; width:460px; border:1px solid #2a2a4a; position:relative;">
    
    <!-- Close -->
    <button onclick="closeModal()" style="position:absolute; top:16px; right:16px; background:#2a2a4a; border:none; color:#aaa; width:30px; height:30px; border-radius:50%; cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center;">✕</button>

    <h3 style="font-family:'Poppins',sans-serif; font-size:16px; font-weight:700; color:#fff; margin:0 0 24px;">Create New Coupon</h3>

  <form id="couponForm">

  <div style="margin-bottom:16px;">
    <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:6px;">Coupon Code *</label>
    <input type="text" name="code" placeholder="e.g. SAVE100" required
      style="width:100%; padding:10px 14px; background:#1a1a2e; border:1px solid #2a2a4a; border-radius:8px; font-size:13px; font-family:'Poppins',sans-serif; color:#fff; outline:none; box-sizing:border-box; text-transform:uppercase;">
  </div>

  <!-- Discount Type toggle -->
  <div style="margin-bottom:16px;">
    <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:8px;">Discount Type *</label>
    <div style="display:flex; gap:10px;">
      <label style="flex:1; display:flex; align-items:center; gap:8px; padding:10px 14px; border:1px solid #2a2a4a; border-radius:8px; cursor:pointer; background:#1a1a2e;" id="flatLabel">
        <input type="radio" name="discountType" value="flat" checked onchange="toggleDiscountType()" style="accent-color:#c0415a;">
        <span style="font-family:'Poppins',sans-serif; font-size:13px; color:#fff;">Flat (₹)</span>
      </label>
      <label style="flex:1; display:flex; align-items:center; gap:8px; padding:10px 14px; border:1px solid #2a2a4a; border-radius:8px; cursor:pointer; background:#1a1a2e;" id="percentLabel">
        <input type="radio" name="discountType" value="percentage" onchange="toggleDiscountType()" style="accent-color:#c0415a;">
        <span style="font-family:'Poppins',sans-serif; font-size:13px; color:#fff;">Percentage (%)</span>
      </label>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px;">
    <div>
      <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:6px;" id="discountLabel">Discount Amount (₹) *</label>
      <input type="number" name="discountAmount" placeholder="e.g. 100" required min="1"
        style="width:100%; padding:10px 14px; background:#1a1a2e; border:1px solid #2a2a4a; border-radius:8px; font-size:13px; font-family:'Poppins',sans-serif; color:#fff; outline:none; box-sizing:border-box;">
    </div>
    <!-- Max discount cap — only shown for percentage -->
    <div id="maxDiscountGroup" style="display:none;">
      <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:6px;">Max Discount Cap (₹)</label>
      <input type="number" name="maxDiscount" placeholder="Optional cap" min="1"
        style="width:100%; padding:10px 14px; background:#1a1a2e; border:1px solid #2a2a4a; border-radius:8px; font-size:13px; font-family:'Poppins',sans-serif; color:#fff; outline:none; box-sizing:border-box;">
    </div>
    <!-- Min order — only shown for flat (for percentage it's optional but still included) -->
    <div id="minOrderGroup">
      <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:6px;">Min Order Amount (₹)</label>
      <input type="number" name="minOrderAmount" placeholder="Optional" min="0"
        style="width:100%; padding:10px 14px; background:#1a1a2e; border:1px solid #2a2a4a; border-radius:8px; font-size:13px; font-family:'Poppins',sans-serif; color:#fff; outline:none; box-sizing:border-box;">
    </div>
    <div>
      <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:6px;">Max Uses</label>
      <input type="number" name="maxUses" placeholder="Optional" min="1"
        style="width:100%; padding:10px 14px; background:#1a1a2e; border:1px solid #2a2a4a; border-radius:8px; font-size:13px; font-family:'Poppins',sans-serif; color:#fff; outline:none; box-sizing:border-box;">
    </div>
  </div>

  <div style="margin-bottom:24px;">
    <label style="font-family:'Poppins',sans-serif; font-size:12px; font-weight:500; color:#aaa; display:block; margin-bottom:6px;">Expiry Date</label>
    <input type="date" name="expiresAt" id="expiresAt"
  style="width:100%; padding:10px 14px; background:#1a1a2e; border:1px solid #2a2a4a; border-radius:8px; font-size:13px; font-family:'Poppins',sans-serif; color:#fff; outline:none; box-sizing:border-box; color-scheme:dark;">
  </div>

  <p id="formMsg" style="display:none; font-size:12px; font-family:'Poppins',sans-serif; margin:0 0 14px;"></p>

  <div style="display:flex; gap:10px;">
    <button type="button" onclick="closeModal()" style="flex:1; padding:11px; background:#2a2a4a; color:#aaa; border:none; border-radius:8px; font-size:13px; font-weight:600; font-family:'Poppins',sans-serif; cursor:pointer;">Cancel</button>
    <button type="submit" style="flex:1; padding:11px; background:#c0415a; color:#fff; border:none; border-radius:8px; font-size:13px; font-weight:600; font-family:'Poppins',sans-serif; cursor:pointer;">Create Coupon</button>
  </div>

</form>
   
  </div>
</div>
<script>
  // Set min date to tomorrow on modal open
function setMinDate() {
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  const yyyy = tomorrow.getFullYear();
  const mm   = String(tomorrow.getMonth() + 1).padStart(2, '0');
  const dd   = String(tomorrow.getDate()).padStart(2, '0');
  document.getElementById('expiresAt').min = `${yyyy}-${mm}-${dd}`;
}
  function toggleDiscountType() {
    const isPercent = document.querySelector('input[name="discountType"]:checked').value === 'percentage'
    document.getElementById('maxDiscountGroup').style.display = isPercent ? 'block' : 'none'
    document.getElementById('discountLabel').textContent = isPercent ? 'Discount (%) *' : 'Discount Amount (₹) *'
    // shift minOrder to second column when percent (maxDiscount takes first slot)
    const minOrderGroup = document.getElementById('minOrderGroup')
    minOrderGroup.style.display = 'block'
  }

  function openModal() {
    document.getElementById('couponModal').style.display = 'flex'
    setMinDate()
  }

  function closeModal() {
    document.getElementById('couponModal').style.display = 'none'
    document.getElementById('couponForm').reset()
    document.getElementById('formMsg').style.display = 'none'
    document.getElementById('maxDiscountGroup').style.display = 'none'
    document.getElementById('discountLabel').textContent = 'Discount Amount (₹) *'
  }

  document.getElementById('couponModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal()
  })

  document.getElementById('couponForm').addEventListener('submit', async (e) => {
    e.preventDefault()
    const form = e.target
    const msg  = document.getElementById('formMsg')

    const type     = form.discountType.value
    const amount   = parseFloat(form.discountAmount.value) || 0
    const minOrder = parseFloat(form.minOrderAmount.value) || 0

    if (amount <= 0) {
      msg.style.display = 'block'; msg.style.color = '#e57373'
      msg.textContent = 'Discount value must be greater than 0.'; return
    }
    if (type === 'percentage' && amount > 90) {
      msg.style.display = 'block'; msg.style.color = '#e57373'
      msg.textContent = 'Percentage discount cannot exceed 90%.'; return
    }
    if (type === 'flat' && minOrder > 0 && minOrder < amount * 2) {
      msg.style.display = 'block'; msg.style.color = '#e57373'
      msg.textContent = `Min Order must be at least 2× the discount (₹${amount * 2} or more).`; return
    }

    const data = {
      code:           form.code.value,
      discountType:   type,
      discountAmount: amount,
      maxDiscount:    form.maxDiscount?.value || null,
      minOrderAmount: form.minOrderAmount.value,
      maxUses:        form.maxUses.value,
      expiresAt:      form.expiresAt.value
    }

    const res    = await fetch('/admin/coupons/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    const result = await res.json()

    msg.style.display = 'block'
    msg.style.color   = result.success ? '#81c784' : '#e57373'
    msg.textContent   = result.message

    if (result.success) setTimeout(() => { closeModal(); location.reload() }, 800)
  })

  async function toggleCoupon(id, checkbox) {
    const res    = await fetch(`/admin/coupons/${id}/toggle`, { method: 'PATCH' })
    const result = await res.json()
    if (result.success) location.reload()
    else checkbox.checked = !checkbox.checked
  }

  async function deleteCoupon(id) {
    if (!confirm('Delete this coupon?')) return
    const res    = await fetch(`/admin/coupons/${id}`, { method: 'DELETE' })
    const result = await res.json()
    if (result.success) location.reload()
  }
</script>

<%- include('../partials/admin/adminFooter') %>
