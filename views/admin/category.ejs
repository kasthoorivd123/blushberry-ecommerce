<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Categories | Blushberry Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:          #0d0608;
      --surface:     #130a0d;
      --surface2:    #1c1014;
      --border:      #2e1a20;
      --accent:      #f4a7bc;
      --accent-dim:  #d4839d;
      --accent-glow: rgba(244,167,188,0.07);
      --text:        #fdf0f3;
      --muted:       #8a6d74;
      --danger-dim:  rgba(192,57,43,0.14);
      --success-dim: rgba(46,204,113,0.10);
      --radius:      8px;
      --radius-lg:   12px;
      --display:     'Playfair Display', Georgia, serif;
      --body:        'DM Sans', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      background-image:
        radial-gradient(ellipse 80% 60% at 90% 0%,   rgba(244,167,188,0.06) 0%, transparent 55%),
        radial-gradient(ellipse 40% 40% at 5%  100%, rgba(244,167,188,0.04) 0%, transparent 50%);
      color: var(--text); font-family: var(--body); font-weight: 300; line-height: 1.6; min-height: 100vh;
    }
    .admin-wrapper { display: flex; min-height: 100vh; }
    .admin-main    { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .admin-content { flex: 1; padding: 2.5rem; width: 100%; max-width: 1100px; margin: 0 auto; }

    /* ── HEADER ── */
    .page-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 1.4rem; border-bottom: 1px solid rgba(244,167,188,0.1); gap: 1rem; flex-wrap: wrap; }
    .breadcrumb { display: flex; align-items: center; gap: 0.45rem; font-size: 0.7rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
    .breadcrumb a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { opacity: 0.35; font-size: 0.58rem; }
    .page-title { font-family: var(--display); font-size: 1.9rem; font-weight: 700; color: var(--text); letter-spacing: -0.01em; line-height: 1.1; }
    .page-title span { color: var(--accent); }
    .page-meta { font-size: 0.78rem; color: var(--muted); margin-top: 0.25rem; }

    /* ── TOOLBAR ── */
    .toolbar { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .search-form { display: flex; align-items: center; flex: 1; min-width: 220px; max-width: 420px; }
    .search-wrap { position: relative; flex: 1; }
    .search-icon { position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.75rem; pointer-events: none; }
    .search-input { width: 100%; background: var(--surface); border: 1px solid var(--border); border-right: none; color: var(--text); padding: 0.58rem 2.2rem 0.58rem 2.1rem; border-radius: var(--radius) 0 0 var(--radius); font-family: var(--body); font-size: 0.84rem; outline: none; transition: border-color 0.2s; }
    .search-input::placeholder { color: var(--muted); }
    .search-input:focus { border-color: var(--accent-dim); }
    .search-clear { position: absolute; right: 0.65rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.72rem; display: none; align-items: center; transition: color 0.2s; }
    .search-clear:hover { color: var(--accent); }
    .search-clear.visible { display: flex; }
    .btn-search { background: var(--accent); color: #1a0a10; border: 1px solid var(--accent); padding: 0.58rem 0.95rem; border-radius: 0 var(--radius) var(--radius) 0; font-family: var(--body); font-size: 0.8rem; font-weight: 500; cursor: pointer; transition: background 0.2s; }
    .btn-search:hover { background: var(--accent-dim); }
    .btn-reset { display: inline-flex; align-items: center; gap: 0.4rem; background: transparent; border: 1px solid var(--border); color: var(--muted); padding: 0.58rem 0.95rem; border-radius: var(--radius); font-family: var(--body); font-size: 0.8rem; cursor: pointer; text-decoration: none; transition: border-color 0.2s, color 0.2s; }
    .btn-reset:hover { border-color: var(--accent-dim); color: var(--accent); }
    .toolbar-right { margin-left: auto; }
    .total-badge { font-size: 0.76rem; color: var(--muted); background: var(--surface); border: 1px solid var(--border); padding: 0.38rem 0.8rem; border-radius: 999px; }
    .total-badge strong { color: var(--accent); font-weight: 500; }

    /* ── TABLE ── */
    .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 1.5rem; }
    .cat-table { width: 100%; border-collapse: collapse; }
    .cat-table thead tr { background: var(--surface2); border-bottom: 1px solid var(--border); }
    .cat-table th { padding: 0.8rem 1.1rem; font-size: 0.67rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); font-weight: 500; text-align: left; white-space: nowrap; }
    .cat-table th:first-child { width: 60px; text-align: center; }
    .cat-table th.th-center  { text-align: center; }
    .cat-table th.th-actions { text-align: center; width: 110px; }
    .cat-table tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; }
    .cat-table tbody tr:last-child { border-bottom: none; }
    .cat-table tbody tr:hover { background: var(--accent-glow); }
    .cat-table td { padding: 0.95rem 1.1rem; font-size: 0.84rem; vertical-align: middle; }
    .cat-table td:first-child { text-align: center; color: var(--muted); font-size: 0.76rem; }
    .cat-name { font-family: var(--display); font-size: 0.92rem; font-weight: 600; color: var(--text); }
    .cat-desc { color: var(--muted); font-size: 0.78rem; max-width: 260px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .offer-badge { display: inline-flex; align-items: center; gap: 0.28rem; background: rgba(244,167,188,0.11); color: var(--accent); border: 1px solid rgba(244,167,188,0.25); font-size: 0.7rem; font-weight: 500; padding: 0.22rem 0.55rem; border-radius: 999px; }
    .no-offer { color: var(--muted); font-size: 0.76rem; }
    .count-pill { display: inline-block; background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-size: 0.76rem; padding: 0.18rem 0.6rem; border-radius: 999px; min-width: 30px; text-align: center; }

    /* ── TOGGLE ── */
    .toggle-wrap { display: flex; align-items: center; gap: 0.55rem; justify-content: center; }
    .toggle-form { display: contents; }
    .switch { position: relative; display: inline-block; width: 36px; height: 20px; cursor: pointer; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; inset: 0; background: var(--border); border-radius: 999px; transition: background 0.25s; }
    .slider::before { content: ''; position: absolute; width: 14px; height: 14px; left: 3px; top: 3px; background: var(--muted); border-radius: 50%; transition: transform 0.25s, background 0.25s; }
    .switch input:checked + .slider { background: rgba(244,167,188,0.22); }
    .switch input:checked + .slider::before { transform: translateX(16px); background: var(--accent); }
    .status-label { font-size: 0.76rem; }
    .status-label.listed   { color: var(--accent); }
    .status-label.unlisted { color: var(--muted); }

    /* ── ACTION BUTTONS ── */
    .action-cell { text-align: center; }
    .action-btns { display: inline-flex; align-items: center; gap: 0.45rem; }
    .act-btn { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: var(--radius); border: 1px solid var(--border); background: transparent; color: var(--muted); cursor: pointer; font-size: 0.76rem; transition: all 0.18s; text-decoration: none; }
    .act-btn:hover        { border-color: var(--accent-dim); color: var(--accent); background: var(--accent-glow); }
    .act-btn.delete:hover { border-color: rgba(192,57,43,0.45); color: #e06c6c; background: var(--danger-dim); }
    .act-btn:disabled     { opacity: 0.28; cursor: not-allowed; pointer-events: none; }

    /* ── EMPTY STATE ── */
    .empty-state { padding: 4rem 2rem; text-align: center; }
    .empty-icon  { font-size: 2.2rem; color: var(--border); margin-bottom: 1rem; }
    .empty-title { font-family: var(--display); font-size: 1.2rem; color: var(--text); margin-bottom: 0.35rem; }
    .empty-sub   { font-size: 0.82rem; color: var(--muted); margin-bottom: 1.5rem; }

    /* ── PAGINATION ── */
    .pagination-wrap {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.1rem; border-top: 1px solid var(--border);
      flex-wrap: wrap; gap: 0.7rem;
    }
    .pagination-info { font-size: 0.76rem; color: var(--muted); }
    .pagination-info strong { color: var(--text); font-weight: 500; }
    .pagination { display: flex; align-items: center; gap: 0.28rem; list-style: none; }
    .page-link {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 32px; height: 32px; padding: 0 0.45rem;
      border: 1px solid var(--border); border-radius: var(--radius);
      background: transparent; color: var(--muted);
      font-family: var(--body); font-size: 0.8rem; text-decoration: none; transition: all 0.18s;
      cursor: pointer;
    }
    .page-link:hover                 { border-color: var(--accent-dim); color: var(--accent); }
    .page-item.active   .page-link   { background: rgba(244,167,188,0.12); border-color: var(--accent-dim); color: var(--accent); font-weight: 500; }
    .page-item.disabled .page-link   { opacity: 0.28; pointer-events: none; cursor: default; }
    .page-item.ellipsis .page-link   { border-color: transparent; cursor: default; pointer-events: none; }

    /* ── BOTTOM BAR ── */
    .bottom-bar { display: flex; justify-content: flex-end; margin-top: 0.25rem; }
    .btn-add { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--accent); color: #1a0a10; border: none; padding: 0.65rem 1.5rem; border-radius: var(--radius); font-family: var(--body); font-size: 0.88rem; font-weight: 500; cursor: pointer; text-decoration: none; transition: background 0.2s, transform 0.15s; }
    .btn-add:hover { background: var(--accent-dim); transform: translateY(-1px); }

    /* ── VALIDATION TOAST OVERRIDE ── */
    .swal2-validation-message { background: rgba(192,57,43,0.12) !important; color: #e06c6c !important; }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: none; } }

    @media (max-width: 768px) {
      .admin-content { padding: 1.1rem; }
      .col-desc, .col-offer { display: none; }
      .toolbar { flex-direction: column; align-items: stretch; }
      .toolbar-right { margin-left: 0; }
      .search-form { max-width: 100%; }
      .pagination-wrap { flex-direction: column; align-items: center; }
      .bottom-bar { justify-content: center; }
    }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('../partials/admin/adminSidebar') %>
  <div class="admin-main">
    <div class="admin-content">

      <!-- PAGE HEADER -->
      <div class="page-header">
        <div>
          <div class="breadcrumb">
            <a href="/admin/dashboard">Dashboard</a>
            <span class="breadcrumb-sep"><i class="fas fa-chevron-right"></i></span>
            <span>Categories</span>
          </div>
          <h1 class="page-title">Category <span>Management</span></h1>
          <p class="page-meta">Manage your lipstick product categories.</p>
        </div>
      </div>

      <!-- TOOLBAR -->
      <div class="toolbar">
        <form class="search-form" action="/admin/category" method="GET">
          <div class="search-wrap">
            <i class="fas fa-search search-icon"></i>
            <input
              type="text" class="search-input"
              name="search" id="searchInput"
              placeholder="Search categories…"
              value="<%= locals.searchQuery || '' %>"
              autocomplete="off"
            />
            <button type="button" class="search-clear <%= (locals.searchQuery && searchQuery.length > 0) ? 'visible' : '' %>" id="searchClear" onclick="clearSearch()">
              <i class="fas fa-times"></i>
            </button>
          </div>
          <button type="submit" class="btn-search"><i class="fas fa-search"></i></button>
        </form>
        <% if (locals.searchQuery && searchQuery.length > 0) { %>
          <a href="/admin/category" class="btn-reset"><i class="fas fa-undo"></i> Reset</a>
        <% } %>
        <div class="toolbar-right">
          <span class="total-badge">Total: <strong><%= locals.totalCategories || 0 %></strong></span>
        </div>
      </div>

      <!-- TABLE -->
      <div class="table-card">
        <% if (locals.categories && categories.length > 0) { %>
          <table class="cat-table">
            <thead>
              <tr>
                <th>S.No</th>
                <th>Category Name</th>
                <th class="col-desc">Description</th>
                <th class="col-offer th-center">Offer</th>
                <th class="th-center">Products</th>
                <th class="th-center">List / Unlist</th>
                <th class="th-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% categories.forEach(function(category, index) { %>
                <tr id="row-<%= category._id %>">
                  <td><%= totalCategories - ((currentPage - 1) * limit + index) %></td>
                  <td><div class="cat-name"><%= category.name %></div></td>
                  <td class="col-desc">
                    <div class="cat-desc" title="<%= category.description %>"><%= category.description %></div>
                  </td>
                  <td class="col-offer" style="text-align:center;">
                    <% if (category.offer && category.offer > 0) { %>
                      <span class="offer-badge"><i class="fas fa-tag"></i> <%= category.offer %>% OFF</span>
                    <% } else { %>
                      <span class="no-offer">—</span>
                    <% } %>
                  </td>
                  <td style="text-align:center;">
                    <span class="count-pill"><%= category.productCount || 0 %></span>
                  </td>
                  <td style="text-align:center;">
                    <form action="/admin/toggleCategoryListing/<%= category._id %>" method="POST" class="toggle-form">
                      <div class="toggle-wrap">
                        <label class="switch">
                          <input type="checkbox" <%= category.isListed ? 'checked' : '' %> onchange="toggleListing('<%= category._id %>', this)" />
                          <span class="slider"></span>
                        </label>
                        <span class="status-label <%= category.isListed ? 'listed' : 'unlisted' %>">
                          <%= category.isListed ? 'Listed' : 'Unlisted' %>
                        </span>
                      </div>
                    </form>
                  </td>
                  <td class="action-cell">
                    <div class="action-btns">
                      <a href="/admin/editCategory/<%= category._id %>" class="act-btn" title="Edit">
                        <i class="fas fa-pen"></i>
                      </a>
                      <button
                        class="act-btn delete"
                        title="<%= category.productCount > 0 ? 'Cannot delete — has products' : 'Delete' %>"
                        <%= category.productCount > 0 ? 'disabled' : '' %>
                        onclick="confirmDelete('<%= category._id %>', `<%= category.name.replace(/`/g,'\\`') %>`)"
                      ><i class="fas fa-trash-alt"></i></button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>

          <!-- ── PAGINATION ── -->
          <% if (locals.totalPages && totalPages > 1) { %>
            <div class="pagination-wrap">
              <div class="pagination-info">
                Showing
                <strong><%= (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit, totalCategories) %></strong>
                of <strong><%= totalCategories %></strong> categories
              </div>
              <ul class="pagination">

                <!-- Prev -->
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="/admin/category?page=<%= currentPage - 1 %>&search=<%= locals.searchQuery || '' %>">
                    <i class="fas fa-chevron-left" style="font-size:0.65rem"></i>
                  </a>
                </li>

                <%
                  let sp = Math.max(1, currentPage - 2);
                  let ep = Math.min(totalPages, sp + 4);
                  if (ep - sp < 4) sp = Math.max(1, ep - 4);
                %>

                <% if (sp > 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="/admin/category?page=1&search=<%= locals.searchQuery || '' %>">1</a>
                  </li>
                  <% if (sp > 2) { %>
                    <li class="page-item ellipsis"><span class="page-link">…</span></li>
                  <% } %>
                <% } %>

                <% for (let p = sp; p <= ep; p++) { %>
                  <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="/admin/category?page=<%= p %>&search=<%= locals.searchQuery || '' %>"><%= p %></a>
                  </li>
                <% } %>

                <% if (ep < totalPages) { %>
                  <% if (ep < totalPages - 1) { %>
                    <li class="page-item ellipsis"><span class="page-link">…</span></li>
                  <% } %>
                  <li class="page-item">
                    <a class="page-link" href="/admin/category?page=<%= totalPages %>&search=<%= locals.searchQuery || '' %>"><%= totalPages %></a>
                  </li>
                <% } %>

                <!-- Next -->
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="/admin/category?page=<%= currentPage + 1 %>&search=<%= locals.searchQuery || '' %>">
                    <i class="fas fa-chevron-right" style="font-size:0.65rem"></i>
                  </a>
                </li>

              </ul>
            </div>
          <% } %>

        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-folder-open"></i></div>
            <h3 class="empty-title">
              <% if (locals.searchQuery && searchQuery.length > 0) { %>
                No results for "<%= searchQuery %>"
              <% } else { %>No categories yet<% } %>
            </h3>
            <p class="empty-sub">
              <% if (locals.searchQuery && searchQuery.length > 0) { %>
                Try a different keyword or <a href="/admin/category" style="color:var(--accent);text-decoration:none">clear the search</a>.
              <% } else { %>Use the button below to add your first category.<% } %>
            </p>
          </div>
        <% } %>
      </div><!-- /.table-card -->

      <!-- ADD BUTTON AT BOTTOM -->
      <div class="bottom-bar">
        <a href="/admin/addCategory" class="btn-add">
          <i class="fas fa-plus"></i> Add Category
        </a>
      </div>

    </div>
    <%- include('../partials/admin/adminFooter') %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script>

  /* ════════════════════════════════════════════
     VALIDATION RULES
     Used by addCategory and editCategory pages
     via sessionStorage message passing.
     On THIS page we just handle delete + search.
  ════════════════════════════════════════════ */

  /*
   * Shared validation function — also exported so
   * addCategory.ejs / editCategory.ejs can call it.
   *
   * Rules:
   *  name        - required, no pure numbers, min 3 chars, max 50 chars
   *  description - required, no pure numbers, min 10 chars, max 300 chars
   *  offer       - optional, 0–100 integer only
   */
  function validateCategoryForm(name, description, offer) {
    var errors = [];

    /* ── NAME ── */
    if (!name || !name.trim()) {
      errors.push('Category name is required.');
    } else if (/^\d+$/.test(name.trim())) {
      errors.push('Category name cannot be only numbers. Use a descriptive name like "Matte" or "Glossy".');
    } else if (name.trim().length < 3) {
      errors.push('Category name must be at least 3 characters.');
    } else if (name.trim().length > 50) {
      errors.push('Category name cannot exceed 50 characters.');
    } else if (/^[^a-zA-Z]+$/.test(name.trim())) {
      errors.push('Category name must contain at least one letter.');
    }

    /* ── DESCRIPTION ── */
    if (!description || !description.trim()) {
      errors.push('Description is required.');
    } else if (/^\d+$/.test(description.trim())) {
      errors.push('Description cannot be only numbers. Please describe the category.');
    } else if (description.trim().length < 10) {
      errors.push('Description must be at least 10 characters.');
    } else if (description.trim().length > 300) {
      errors.push('Description cannot exceed 300 characters.');
    } else if (/^[^a-zA-Z]+$/.test(description.trim())) {
      errors.push('Description must contain at least one letter.');
    }

    /* ── OFFER ── */
    if (offer !== '' && offer !== null && offer !== undefined) {
      var offerNum = Number(offer);
      if (isNaN(offerNum) || !Number.isInteger(offerNum)) {
        errors.push('Offer must be a whole number (e.g. 10).');
      } else if (offerNum < 0 || offerNum > 100) {
        errors.push('Offer must be between 0 and 100.');
      }
    }

    return errors; // empty array = valid
  }

  /* ── TOAST ── */
  function showToast(message, type) {
    Swal.fire({
      toast: true, position: 'top-end', icon: type, title: message,
      showConfirmButton: false, timer: 3500, timerProgressBar: true,
      background: '#130a0d', color: '#fdf0f3',
      iconColor: type === 'success' ? '#f4a7bc' : '#e06c6c'
    });
  }

  /* ── DELETE ── */
  function confirmDelete(id, name) {
    Swal.fire({
      title: 'Delete "' + name + '"?',
      text:  'This category will be soft-deleted and hidden from the storefront.',
      icon:  'warning',
      background: '#130a0d', color: '#fdf0f3', iconColor: '#f4a7bc',
      showCancelButton: true,
      confirmButtonText: 'Yes, delete',
      cancelButtonText:  'Cancel',
      confirmButtonColor: '#c0392b',
      cancelButtonColor:  '#2e1a20'
    }).then(async function(result) {
      if (!result.isConfirmed) return;
      try {
        var res  = await fetch('/admin/deleteCategory/' + id, {
          method: 'DELETE', headers: { 'Content-Type': 'application/json' }
        });
        var data = await res.json();
        if (data.success) {
          showToast(data.message || 'Category deleted', 'success');
          var row = document.getElementById('row-' + id);
          if (row) { row.style.transition = 'opacity 0.4s'; row.style.opacity = '0'; }
          setTimeout(function() { location.reload(); }, 1000);
        } else {
          showToast(data.message || 'Could not delete', 'error');
        }
      } catch(err) {
        showToast('Something went wrong', 'error');
      }
    });
  }

  /* ── SEARCH CLEAR ── */
  var searchInput = document.getElementById('searchInput');
  var searchClear = document.getElementById('searchClear');
  searchInput.addEventListener('input', function() {
    searchClear.classList.toggle('visible', this.value.length > 0);
  });
  function clearSearch() {
    searchInput.value = '';
    searchClear.classList.remove('visible');
    window.location.href = '/admin/category';
  }

  /* ── Show redirect toast if coming back from add/edit ── */
  window.addEventListener('DOMContentLoaded', function() {
    var msg  = sessionStorage.getItem('cat_toast_msg');
    var type = sessionStorage.getItem('cat_toast_type');
    if (msg) {
      showToast(msg, type || 'success');
      sessionStorage.removeItem('cat_toast_msg');
      sessionStorage.removeItem('cat_toast_type');
    }
  });

  async function toggleListing(id, checkbox) {
    try {
        var res  = await fetch('/admin/toggleCategoryListing/' + id, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        var data = await res.json()

        if (data.success) {
            showToast(data.message, 'success')
            var label = checkbox.closest('.toggle-wrap').querySelector('.status-label')
            if (checkbox.checked) {
                label.textContent = 'Listed'
                label.className   = 'status-label listed'
            } else {
                label.textContent = 'Unlisted'
                label.className   = 'status-label unlisted'
            }
        } else {
            showToast(data.message, 'error')
            checkbox.checked = !checkbox.checked  // revert if failed
        }
    } catch(err) {
        showToast('Something went wrong', 'error')
        checkbox.checked = !checkbox.checked  // revert if failed
    }
}

</script>
</body>
</html>
