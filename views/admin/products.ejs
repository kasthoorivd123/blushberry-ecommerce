<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products | Blushberry Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:          #0d0608;
      --surface:     #130a0d;
      --surface2:    #1c1014;
      --border:      #2e1a20;
      --accent:      #f4a7bc;
      --accent-dim:  #d4839d;
      --accent-glow: rgba(244,167,188,0.07);
      --text:        #fdf0f3;
      --muted:       #8a6d74;
      --danger-dim:  rgba(192,57,43,0.14);
      --radius:      8px;
      --radius-lg:   12px;
      --display:     'Playfair Display', Georgia, serif;
      --body:        'DM Sans', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      background-image:
        radial-gradient(ellipse 80% 60% at 90% 0%, rgba(244,167,188,0.06) 0%, transparent 55%),
        radial-gradient(ellipse 40% 40% at 5% 100%, rgba(244,167,188,0.04) 0%, transparent 50%);
      color: var(--text); font-family: var(--body); font-weight: 300; line-height: 1.6; min-height: 100vh;
    }
    .admin-wrapper { display: flex; min-height: 100vh; }
    .admin-main    { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .admin-content { flex: 1; padding: 2.5rem; width: 100%; max-width: 1200px; margin: 0 auto; }

    /* ── HEADER ── */
    .page-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 1.4rem; border-bottom: 1px solid rgba(244,167,188,0.1); gap: 1rem; flex-wrap: wrap; }
    .breadcrumb { display: flex; align-items: center; gap: 0.45rem; font-size: 0.7rem; letter-spacing: 0.13em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
    .breadcrumb a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { opacity: 0.35; font-size: 0.58rem; }
    .page-title { font-family: var(--display); font-size: 1.9rem; font-weight: 700; color: var(--text); letter-spacing: -0.01em; line-height: 1.1; }
    .page-title span { color: var(--accent); }
    .page-meta { font-size: 0.78rem; color: var(--muted); margin-top: 0.25rem; }

    /* ── TOOLBAR ── */
    .toolbar { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .search-form { display: flex; align-items: center; flex: 1; min-width: 220px; max-width: 420px; }
    .search-wrap { position: relative; flex: 1; }
    .search-icon { position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.75rem; pointer-events: none; }
    .search-input { width: 100%; background: var(--surface); border: 1px solid var(--border); border-right: none; color: var(--text); padding: 0.58rem 2.2rem 0.58rem 2.1rem; border-radius: var(--radius) 0 0 var(--radius); font-family: var(--body); font-size: 0.84rem; outline: none; transition: border-color 0.2s; }
    .search-input::placeholder { color: var(--muted); }
    .search-input:focus { border-color: var(--accent-dim); }
    .search-clear { position: absolute; right: 0.65rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.72rem; display: none; align-items: center; transition: color 0.2s; }
    .search-clear:hover { color: var(--accent); }
    .search-clear.visible { display: flex; }
    .btn-search { background: var(--accent); color: #1a0a10; border: 1px solid var(--accent); padding: 0.58rem 0.95rem; border-radius: 0 var(--radius) var(--radius) 0; font-family: var(--body); font-size: 0.8rem; font-weight: 500; cursor: pointer; transition: background 0.2s; }
    .btn-search:hover { background: var(--accent-dim); }
    .btn-reset { display: inline-flex; align-items: center; gap: 0.4rem; background: transparent; border: 1px solid var(--border); color: var(--muted); padding: 0.58rem 0.95rem; border-radius: var(--radius); font-family: var(--body); font-size: 0.8rem; cursor: pointer; text-decoration: none; transition: border-color 0.2s, color 0.2s; }
    .btn-reset:hover { border-color: var(--accent-dim); color: var(--accent); }
    .toolbar-right { margin-left: auto; }
    .total-badge { font-size: 0.76rem; color: var(--muted); background: var(--surface); border: 1px solid var(--border); padding: 0.38rem 0.8rem; border-radius: 999px; }
    .total-badge strong { color: var(--accent); font-weight: 500; }

    /* ── TABLE ── */
    .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 1.5rem; }
    .prod-table { width: 100%; border-collapse: collapse; }
    .prod-table thead tr { background: var(--surface2); border-bottom: 1px solid var(--border); }
    .prod-table th { padding: 0.8rem 1.1rem; font-size: 0.67rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); font-weight: 500; text-align: left; white-space: nowrap; }
    .prod-table th:first-child { width: 55px; text-align: center; }
    .prod-table th.th-center { text-align: center; }
    .prod-table th.th-actions { text-align: center; width: 110px; }
    .prod-table tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; }
    .prod-table tbody tr:last-child { border-bottom: none; }
    .prod-table tbody tr:hover { background: var(--accent-glow); }
    .prod-table td { padding: 0.85rem 1.1rem; font-size: 0.84rem; vertical-align: middle; }
    .prod-table td:first-child { text-align: center; color: var(--muted); font-size: 0.76rem; }

    /* product image thumb */
    .prod-thumb {
      width: 46px; height: 46px; border-radius: var(--radius);
      object-fit: cover; border: 1px solid var(--border);
      background: var(--surface2);
    }
    .prod-thumb-placeholder {
      width: 46px; height: 46px; border-radius: var(--radius);
      border: 1px solid var(--border); background: var(--surface2);
      display: flex; align-items: center; justify-content: center;
      color: var(--muted); font-size: 1rem;
    }
    .prod-name { font-family: var(--display); font-size: 0.92rem; font-weight: 600; color: var(--text); }
    .prod-cat  { font-size: 0.72rem; color: var(--muted); margin-top: 0.15rem; }

    .price-wrap { display: flex; flex-direction: column; gap: 0.1rem; }
    .price-original { font-size: 0.72rem; color: var(--muted); text-decoration: line-through; }
    .price-sale { font-size: 0.88rem; color: var(--text); font-weight: 500; }

    .offer-badge { display: inline-flex; align-items: center; gap: 0.28rem; background: rgba(244,167,188,0.11); color: var(--accent); border: 1px solid rgba(244,167,188,0.25); font-size: 0.7rem; font-weight: 500; padding: 0.22rem 0.55rem; border-radius: 999px; }
    .no-offer { color: var(--muted); font-size: 0.76rem; }

    .stock-pill { display: inline-block; font-size: 0.76rem; padding: 0.18rem 0.6rem; border-radius: 999px; min-width: 30px; text-align: center; }
    .stock-ok  { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.2); color: #4cd98a; }
    .stock-low { background: rgba(255,165,0,0.1);  border: 1px solid rgba(255,165,0,0.22); color: #ffb347; }
    .stock-out { background: var(--danger-dim);    border: 1px solid rgba(192,57,43,0.25); color: #e06c6c; }

    /* toggle */
    .toggle-wrap { display: flex; align-items: center; gap: 0.55rem; justify-content: center; }
    .switch { position: relative; display: inline-block; width: 36px; height: 20px; cursor: pointer; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; inset: 0; background: var(--border); border-radius: 999px; transition: background 0.25s; }
    .slider::before { content: ''; position: absolute; width: 14px; height: 14px; left: 3px; top: 3px; background: var(--muted); border-radius: 50%; transition: transform 0.25s, background 0.25s; }
    .switch input:checked + .slider { background: rgba(244,167,188,0.22); }
    .switch input:checked + .slider::before { transform: translateX(16px); background: var(--accent); }
    .status-label { font-size: 0.76rem; }
    .status-label.listed   { color: var(--accent); }
    .status-label.unlisted { color: var(--muted); }

    /* action buttons */
    .action-cell { text-align: center; }
    .action-btns { display: inline-flex; align-items: center; gap: 0.45rem; }
    .act-btn { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: var(--radius); border: 1px solid var(--border); background: transparent; color: var(--muted); cursor: pointer; font-size: 0.76rem; transition: all 0.18s; text-decoration: none; }
    .act-btn:hover        { border-color: var(--accent-dim); color: var(--accent); background: var(--accent-glow); }
    .act-btn.delete:hover { border-color: rgba(192,57,43,0.45); color: #e06c6c; background: var(--danger-dim); }
    .act-btn:disabled     { opacity: 0.28; cursor: not-allowed; pointer-events: none; }

    /* empty */
    .empty-state { padding: 4rem 2rem; text-align: center; }
    .empty-icon  { font-size: 2.2rem; color: var(--border); margin-bottom: 1rem; }
    .empty-title { font-family: var(--display); font-size: 1.2rem; color: var(--text); margin-bottom: 0.35rem; }
    .empty-sub   { font-size: 0.82rem; color: var(--muted); margin-bottom: 1.5rem; }

    /* pagination */
    .pagination-wrap { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.1rem; border-top: 1px solid var(--border); flex-wrap: wrap; gap: 0.7rem; }
    .pagination-info { font-size: 0.76rem; color: var(--muted); }
    .pagination-info strong { color: var(--text); font-weight: 500; }
    .pagination { display: flex; align-items: center; gap: 0.28rem; list-style: none; }
    .page-link { display: inline-flex; align-items: center; justify-content: center; min-width: 32px; height: 32px; padding: 0 0.45rem; border: 1px solid var(--border); border-radius: var(--radius); background: transparent; color: var(--muted); font-family: var(--body); font-size: 0.8rem; text-decoration: none; transition: all 0.18s; cursor: pointer; }
    .page-link:hover { border-color: var(--accent-dim); color: var(--accent); }
    .page-item.active   .page-link { background: rgba(244,167,188,0.12); border-color: var(--accent-dim); color: var(--accent); font-weight: 500; }
    .page-item.disabled .page-link { opacity: 0.28; pointer-events: none; cursor: default; }
    .page-item.ellipsis .page-link { border-color: transparent; cursor: default; pointer-events: none; }

    /* bottom bar */
    .bottom-bar { display: flex; justify-content: flex-end; margin-top: 0.25rem; }
    .btn-add { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--accent); color: #1a0a10; border: none; padding: 0.65rem 1.5rem; border-radius: var(--radius); font-family: var(--body); font-size: 0.88rem; font-weight: 500; cursor: pointer; text-decoration: none; transition: background 0.2s, transform 0.15s; }
    .btn-add:hover { background: var(--accent-dim); transform: translateY(-1px); }

    @media (max-width: 768px) {
      .admin-content { padding: 1.1rem; }
      .col-desc, .col-offer, .col-stock { display: none; }
      .toolbar { flex-direction: column; align-items: stretch; }
      .toolbar-right { margin-left: 0; }
      .search-form { max-width: 100%; }
      .pagination-wrap { flex-direction: column; align-items: center; }
      .bottom-bar { justify-content: center; }
    }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('../partials/admin/adminSidebar') %>
  <div class="admin-main">
    <div class="admin-content">

      <!-- HEADER -->
      <div class="page-header">
        <div>
          <div class="breadcrumb">
            <a href="/admin/dashboard">Dashboard</a>
            <span class="breadcrumb-sep"><i class="fas fa-chevron-right"></i></span>
            <span>Products</span>
          </div>
          <h1 class="page-title">Product <span>Management</span></h1>
          <p class="page-meta">Manage your lipstick products, shades and pricing.</p>
        </div>
      </div>

      <!-- TOOLBAR -->
      <div class="toolbar">
        <form class="search-form" action="/admin/products" method="GET">
            <input type="hidden" name="page" value="1">
          <div class="search-wrap">
            <i class="fas fa-search search-icon"></i>
            <input
              type="text" class="search-input"
              name="search" id="searchInput"
              placeholder="Search products…"
              value="<%= locals.searchQuery || '' %>"
              autocomplete="off"
            />
            <button type="button" class="search-clear <%= (locals.searchQuery && searchQuery.length > 0) ? 'visible' : '' %>" id="searchClear" onclick="clearSearch()">
              <i class="fas fa-times"></i>
            </button>
          </div>
          <button type="submit" class="btn-search"><i class="fas fa-search"></i></button>
        </form>
        <% if (locals.searchQuery && searchQuery.length > 0) { %>
          <a href="/admin/products" class="btn-reset"><i class="fas fa-undo"></i> Reset</a>
        <% } %>
        <div class="toolbar-right">
          <span class="total-badge">Total: <strong><%= locals.totalProducts || 0 %></strong></span>
        </div>
      </div>

      <!-- TABLE -->
      <div class="table-card">
        <% if (locals.products && products.length > 0) { %>
          <table class="prod-table">
            <thead>
              <tr>
                <th>S.No</th>
                <th>Image</th>
                <th>Product</th>
                <th class="col-desc">Category</th>
                <th>Price</th>
                <th class="col-offer th-center">Offer</th>
                <th class="col-stock th-center">Stock</th>
                <th class="th-center">Status</th>
                <th class="th-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(function(product, index) { %>
                <tr id="row-<%= product._id %>">
                  <td><%= totalProducts - ((currentPage - 1) * limit + index) %></td>

                  <!-- image -->
                  <td>
                    <% if (product.images && product.images.length > 0) { %>
                      <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="prod-thumb" />
                    <% } else { %>
                      <div class="prod-thumb-placeholder"><i class="fas fa-image"></i></div>
                    <% } %>
                  </td>

                  <!-- name + category -->
                  <td>
                    <div class="prod-name"><%= product.name %></div>
                    <div class="prod-cat"><%= product.categoryId ? product.categoryId.name : '—' %></div>
                  </td>

                  <!-- category col (hidden on mobile) -->
                  <td class="col-desc" style="color:var(--muted);font-size:0.82rem;">
                    <%= product.categoryId ? product.categoryId.name : '—' %>
                  </td>

                  <!-- price -->
                  <td>
                    <% if (product.variants && product.variants.length > 0) { %>
                      <div class="price-wrap">
                        <% if (product.variants[0].salePrice && product.variants[0].salePrice < product.variants[0].varientPrice) { %>
                          <span class="price-original">₹<%= product.variants[0].varientPrice %></span>
                          <span class="price-sale">₹<%= product.variants[0].salePrice %></span>
                        <% } else { %>
                          <span class="price-sale">₹<%= product.variants[0].varientPrice %></span>
                        <% } %>
                      </div>
                    <% } else { %>
                      <span style="color:var(--muted);">—</span>
                    <% } %>
                  </td>

                  <!-- offer -->
                  <td class="col-offer" style="text-align:center;">
                    <% if (product.offer && product.offer > 0) { %>
                      <span class="offer-badge"><i class="fas fa-tag"></i> <%= product.offer %>% OFF</span>
                    <% } else { %>
                      <span class="no-offer">—</span>
                    <% } %>
                  </td>

                  <!-- total stock across all variants -->
                  <td class="col-stock" style="text-align:center;">
                    <%
                      var totalStock = 0;
                      if (product.variants) {
                        product.variants.forEach(function(v) { totalStock += (v.stock || 0); });
                      }
                    %>
                    <span class="stock-pill <%= totalStock === 0 ? 'stock-out' : totalStock <= 10 ? 'stock-low' : 'stock-ok' %>">
                      <%= totalStock %>
                    </span>
                  </td>

                  <!-- toggle -->
                  <td style="text-align:center;">
                    <div class="toggle-wrap">
                      <label class="switch">
                        <input
                          type="checkbox"
                          <%= product.isListed ? 'checked' : '' %>
                          onchange="toggleProduct('<%= product._id %>', this)"
                        />
                        <span class="slider"></span>
                      </label>
                      <span class="status-label <%= product.isListed ? 'listed' : 'unlisted' %>">
                        <%= product.isListed ? 'Listed' : 'Unlisted' %>
                      </span>
                    </div>
                  </td>

                  <!-- actions -->
                  <td class="action-cell">
                    <div class="action-btns">
                      <a href="/admin/editProduct/<%= product._id %>" class="act-btn" title="Edit">
                        <i class="fas fa-pen"></i>
                      </a>
                      <button
                        class="act-btn delete"
                        title="Delete product"
                        onclick="confirmDelete('<%= product._id %>', `<%= product.name.replace(/`/g,'\\`') %>`)"
                      ><i class="fas fa-trash-alt"></i></button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>

          <!-- PAGINATION -->
          <% if (locals.totalPages && totalPages > 1) { %>
            <div class="pagination-wrap">
              <div class="pagination-info">
                Showing
                <strong><%= (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit, totalProducts) %></strong>
                of <strong><%= totalProducts %></strong> products
              </div>
              <ul class="pagination">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="/admin/products?page=<%= currentPage - 1 %>&search=<%= locals.searchQuery || '' %>">
                    <i class="fas fa-chevron-left" style="font-size:0.65rem"></i>
                  </a>
                </li>
                <%
                  let sp = Math.max(1, currentPage - 2);
                  let ep = Math.min(totalPages, sp + 4);
                  if (ep - sp < 4) sp = Math.max(1, ep - 4);
                %>
                <% if (sp > 1) { %>
                  <li class="page-item"><a class="page-link" href="/admin/products?page=1&search=<%= locals.searchQuery || '' %>">1</a></li>
                  <% if (sp > 2) { %><li class="page-item ellipsis"><span class="page-link">…</span></li><% } %>
                <% } %>
                <% for (let p = sp; p <= ep; p++) { %>
                  <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="/admin/products?page=<%= p %>&search=<%= locals.searchQuery || '' %>"><%= p %></a>
                  </li>
                <% } %>
                <% if (ep < totalPages) { %>
                  <% if (ep < totalPages - 1) { %><li class="page-item ellipsis"><span class="page-link">…</span></li><% } %>
                  <li class="page-item"><a class="page-link" href="/admin/products?page=<%= totalPages %>&search=<%= locals.searchQuery || '' %>"><%= totalPages %></a></li>
                <% } %>
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="/admin/products?page=<%= currentPage + 1 %>&search=<%= locals.searchQuery || '' %>">
                    <i class="fas fa-chevron-right" style="font-size:0.65rem"></i>
                  </a>
                </li>
              </ul>
            </div>
          <% } %>

        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-box-open"></i></div>
            <h3 class="empty-title">
              <% if (locals.searchQuery && searchQuery.length > 0) { %>
                No results for "<%= searchQuery %>"
              <% } else { %>No products yet<% } %>
            </h3>
            <p class="empty-sub">
              <% if (locals.searchQuery && searchQuery.length > 0) { %>
                Try a different keyword or <a href="/admin/products" style="color:var(--accent);text-decoration:none">clear the search</a>.
              <% } else { %>Use the button below to add your first product.<% } %>
            </p>
          </div>
        <% } %>
      </div>

      <!-- BOTTOM BAR -->
      <div class="bottom-bar">
        <a href="/admin/addProduct" class="btn-add">
          <i class="fas fa-plus"></i> Add Product
        </a>
      </div>
   
    </div>
    <%- include('../partials/admin/adminFooter') %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script>
  function showToast(message, type) {
    Swal.fire({
      toast: true, position: 'top-end', icon: type, title: message,
      showConfirmButton: false, timer: 3500, timerProgressBar: true,
      background: '#130a0d', color: '#fdf0f3',
      iconColor: type === 'success' ? '#f4a7bc' : '#e06c6c'
    });
  }

  /* ── TOGGLE ── */
  async function toggleProduct(id, checkbox) {
    try {
      var res  = await fetch('/admin/toggleProductListing/' + id, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }
      });
      var data = await res.json();
      if (data.success) {
        showToast(data.message, 'success');
        var label = checkbox.closest('.toggle-wrap').querySelector('.status-label');
        if (checkbox.checked) {
          label.textContent = 'Listed';
          label.className   = 'status-label listed';
        } else {
          label.textContent = 'Unlisted';
          label.className   = 'status-label unlisted';
        }
      } else {
        showToast(data.message, 'error');
        checkbox.checked = !checkbox.checked;
      }
    } catch(err) {
      showToast('Something went wrong', 'error');
      checkbox.checked = !checkbox.checked;
    }
  }

  /* ── DELETE ── */
  function confirmDelete(id, name) {
    Swal.fire({
      title: 'Delete "' + name + '"?',
      text:  'This product will be soft-deleted and hidden from the storefront.',
      icon:  'warning',
      background: '#130a0d', color: '#fdf0f3', iconColor: '#f4a7bc',
      showCancelButton: true,
      confirmButtonText: 'Yes, delete', cancelButtonText: 'Cancel',
      confirmButtonColor: '#c0392b', cancelButtonColor: '#2e1a20'
    }).then(async function(result) {
      if (!result.isConfirmed) return;
      try {
        var res  = await fetch('/admin/deleteProduct/' + id, {
          method: 'DELETE', headers: { 'Content-Type': 'application/json' }
        });
        var data = await res.json();
        if (data.success) {
          showToast(data.message || 'Product deleted', 'success');
          var row = document.getElementById('row-' + id);
          if (row) { row.style.transition = 'opacity 0.4s'; row.style.opacity = '0'; }
          setTimeout(function() { location.reload(); }, 1000);
        } else {
          showToast(data.message || 'Could not delete', 'error');
        }
      } catch(err) {
        showToast('Something went wrong', 'error');
      }
    });
  }

  /* ── SEARCH CLEAR ── */
  var searchInput = document.getElementById('searchInput');
  var searchClear = document.getElementById('searchClear');
  searchInput.addEventListener('input', function() {
    searchClear.classList.toggle('visible', this.value.length > 0);
  });
  function clearSearch() {
    searchInput.value = '';
    searchClear.classList.remove('visible');
    window.location.href = '/admin/products';
  }

  /* ── TOAST ON REDIRECT FROM ADD/EDIT ── */
  window.addEventListener('DOMContentLoaded', function() {
    var msg  = sessionStorage.getItem('prod_toast_msg');
    var type = sessionStorage.getItem('prod_toast_type');
    if (msg) {
      showToast(msg, type || 'success');
      sessionStorage.removeItem('prod_toast_msg');
      sessionStorage.removeItem('prod_toast_type');
    }
  });
</script>
</body>
</html>
