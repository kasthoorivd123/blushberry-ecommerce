<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orders | Blushberry Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #0d0608;
      --surface: #130a0d;
      --surface2: #1c1014;
      --border: #2e1a20;
      --accent: #f4a7bc;
      --accent-dim: #d4839d;
      --accent-glow: rgba(244, 167, 188, 0.07);
      --text: #fdf0f3;
      --muted: #8a6d74;
      --danger-dim: rgba(192, 57, 43, 0.14);
      --radius: 8px;
      --radius-lg: 12px;
      --display: 'Playfair Display', Georgia, serif;
      --body: 'DM Sans', sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      background-image:
        radial-gradient(ellipse 80% 60% at 90% 0%, rgba(244, 167, 188, 0.06) 0%, transparent 55%),
        radial-gradient(ellipse 40% 40% at 5% 100%, rgba(244, 167, 188, 0.04) 0%, transparent 50%);
      color: var(--text);
      font-family: var(--body);
      font-weight: 300;
      line-height: 1.6;
      min-height: 100vh;
    }

    .admin-wrapper {
      display: flex;
      min-height: 100vh;
    }

    .admin-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .admin-content {
      flex: 1;
      padding: 2.5rem;
      width: 100%;
      max-width: 1300px;
      margin: 0 auto;
    }

    /* HEADER */
    .page-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2rem;
      padding-bottom: 1.4rem;
      border-bottom: 1px solid rgba(244, 167, 188, 0.1);
      gap: 1rem;
      flex-wrap: wrap;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.7rem;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }

    .breadcrumb a {
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .breadcrumb a:hover {
      color: var(--accent);
    }

    .breadcrumb-sep {
      opacity: 0.35;
      font-size: 0.58rem;
    }

    .page-title {
      font-family: var(--display);
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.1;
    }

    .page-title span {
      color: var(--accent);
    }

    .page-meta {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    /* TOOLBAR */
    .toolbar {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .search-form {
      display: flex;
      align-items: center;
      flex: 1;
      min-width: 220px;
      max-width: 380px;
    }

    .search-wrap {
      position: relative;
      flex: 1;
    }

    .search-icon {
      position: absolute;
      left: 0.85rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 0.75rem;
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-right: none;
      color: var(--text);
      padding: 0.58rem 2.2rem 0.58rem 2.1rem;
      border-radius: var(--radius) 0 0 var(--radius);
      font-family: var(--body);
      font-size: 0.84rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input::placeholder {
      color: var(--muted);
    }

    .search-input:focus {
      border-color: var(--accent-dim);
    }

    .search-clear {
      position: absolute;
      right: 0.65rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.72rem;
      display: none;
      align-items: center;
      transition: color 0.2s;
    }

    .search-clear:hover {
      color: var(--accent);
    }

    .search-clear.visible {
      display: flex;
    }

    .btn-search {
      background: var(--accent);
      color: #1a0a10;
      border: 1px solid var(--accent);
      padding: 0.58rem 0.95rem;
      border-radius: 0 var(--radius) var(--radius) 0;
      font-family: var(--body);
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s;
    }

    .btn-search:hover {
      background: var(--accent-dim);
    }

    /* FILTERS */
    .filter-select {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 0.58rem 0.85rem;
      border-radius: var(--radius);
      font-family: var(--body);
      font-size: 0.82rem;
      outline: none;
      cursor: pointer;
      transition: border-color 0.2s;
    }

    .filter-select:focus {
      border-color: var(--accent-dim);
    }

    .filter-select option {
      background: var(--surface2);
    }

    .btn-reset {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 0.58rem 0.95rem;
      border-radius: var(--radius);
      font-family: var(--body);
      font-size: 0.8rem;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
      white-space: nowrap;
    }

    .btn-reset:hover {
      border-color: var(--accent-dim);
      color: var(--accent);
    }

    .toolbar-right {
      margin-left: auto;
    }

    .total-badge {
      font-size: 0.76rem;
      color: var(--muted);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.38rem 0.8rem;
      border-radius: 999px;
      white-space: nowrap;
    }

    .total-badge strong {
      color: var(--accent);
      font-weight: 500;
    }

    /* TABLE */
    .table-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .prod-table {
      width: 100%;
      border-collapse: collapse;
    }

    .prod-table thead tr {
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
    }

    .prod-table th {
      padding: 0.8rem 1.1rem;
      font-size: 0.67rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
      text-align: left;
      white-space: nowrap;
    }

    .prod-table th.th-center {
      text-align: center;
    }

    .prod-table tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }

    .prod-table tbody tr:last-child {
      border-bottom: none;
    }

    .prod-table tbody tr:hover {
      background: var(--accent-glow);
    }

    .prod-table td {
      padding: 0.9rem 1.1rem;
      font-size: 0.84rem;
      vertical-align: middle;
    }

    .order-id {
      font-family: var(--display);
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.03em;
    }

    .order-date {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.15rem;
    }

    .customer-name {
      font-size: 0.86rem;
      font-weight: 500;
      color: var(--text);
    }

    .customer-email {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.1rem;
    }

    .order-amount {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text);
    }

    .order-items-count {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 0.1rem;
    }

    /* STATUS BADGES */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.7rem;
      font-weight: 500;
      padding: 0.22rem 0.65rem;
      border-radius: 999px;
      white-space: nowrap;
    }

    .status-Placed {
      background: rgba(244, 167, 188, 0.12);
      color: var(--accent);
      border: 1px solid rgba(244, 167, 188, 0.25);
    }

    .status-Processing {
      background: rgba(255, 165, 0, 0.1);
      color: #ffb347;
      border: 1px solid rgba(255, 165, 0, 0.25);
    }

    .status-Shipped {
      background: rgba(33, 150, 243, 0.1);
      color: #64b5f6;
      border: 1px solid rgba(33, 150, 243, 0.25);
    }

    .status-Delivered {
      background: rgba(46, 204, 113, 0.1);
      color: #4cd98a;
      border: 1px solid rgba(46, 204, 113, 0.25);
    }

    .status-Cancelled {
      background: var(--danger-dim);
      color: #e06c6c;
      border: 1px solid rgba(192, 57, 43, 0.25);
    }

    .status-Returned {
      background: rgba(103, 58, 183, 0.1);
      color: #b39ddb;
      border: 1px solid rgba(103, 58, 183, 0.25);
    }

    /* ACTION BTNS */
    .action-cell {
      text-align: center;
    }

    .action-btns {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .act-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.76rem;
      transition: all 0.18s;
      text-decoration: none;
    }

    .act-btn:hover {
      border-color: var(--accent-dim);
      color: var(--accent);
      background: var(--accent-glow);
    }

    /* PAYMENT METHOD TAG */
    .pay-tag {
      font-size: 0.68rem;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
    }

    /* EMPTY */
    .empty-state {
      padding: 4rem 2rem;
      text-align: center;
    }

    .empty-icon {
      font-size: 2.2rem;
      color: var(--border);
      margin-bottom: 1rem;
    }

    .empty-title {
      font-family: var(--display);
      font-size: 1.2rem;
      color: var(--text);
      margin-bottom: 0.35rem;
    }

    .empty-sub {
      font-size: 0.82rem;
      color: var(--muted);
    }

    .empty-sub a {
      color: var(--accent);
      text-decoration: none;
    }

    /* PAGINATION */
    .pagination-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.1rem;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .pagination-info {
      font-size: 0.76rem;
      color: var(--muted);
    }

    .pagination-info strong {
      color: var(--text);
      font-weight: 500;
    }

    .pagination {
      display: flex;
      align-items: center;
      gap: 0.28rem;
      list-style: none;
    }

    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 32px;
      height: 32px;
      padding: 0 0.45rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: transparent;
      color: var(--muted);
      font-family: var(--body);
      font-size: 0.8rem;
      text-decoration: none;
      transition: all 0.18s;
      cursor: pointer;
    }

    .page-link:hover {
      border-color: var(--accent-dim);
      color: var(--accent);
    }

    .page-item.active .page-link {
      background: rgba(244, 167, 188, 0.12);
      border-color: var(--accent-dim);
      color: var(--accent);
      font-weight: 500;
    }

    .page-item.disabled .page-link {
      opacity: 0.28;
      pointer-events: none;
      cursor: default;
    }

    .page-item.ellipsis .page-link {
      border-color: transparent;
      cursor: default;
      pointer-events: none;
    }

    @media (max-width: 900px) {
      .admin-content {
        padding: 1.1rem;
      }

      .col-hide {
        display: none;
      }

      .toolbar {
        flex-direction: column;
        align-items: stretch;
      }

      .toolbar-right {
        margin-left: 0;
      }

      .search-form {
        max-width: 100%;
      }
    }
  </style>
</head>

<body>
  <div class="admin-wrapper">
    <%- include('../partials/admin/adminSidebar') %>
      <div class="admin-main">
        <div class="admin-content">

          <!-- HEADER -->
          <div class="page-header">
            <div>
              <div class="breadcrumb">
                <a href="/admin/dashboard">Dashboard</a>
                <span class="breadcrumb-sep"><i class="fas fa-chevron-right"></i></span>
                <span>Orders</span>
              </div>
              <h1 class="page-title">Order <span>Management</span></h1>
              <p class="page-meta">View and manage all customer orders.</p>
            </div>
          </div>

          <!-- TOOLBAR -->
          <form id="filterForm" action="/admin/orders" method="GET">
            <input type="hidden" name="page" value="1" />
            <div class="toolbar">
              <!-- SEARCH -->
              <div class="search-form">
                <div class="search-wrap">
                  <i class="fas fa-search search-icon"></i>
                  <input type="text" class="search-input" name="search" id="searchInput"
                    placeholder="Order ID, customer, product…" value="<%= locals.search || '' %>" autocomplete="off" />
                  <button type="button"
                    class="search-clear <%= (locals.search && search.length > 0) ? 'visible' : '' %>" id="searchClear"
                    onclick="clearSearch()">
                    <i class="fas fa-times"></i>
                  </button>
                </div>
                <button type="submit" class="btn-search"><i class="fas fa-search"></i></button>
              </div>

              <!-- STATUS FILTER -->
              <select class="filter-select" name="status" onchange="document.getElementById('filterForm').submit()">
                <option value="" <%=!locals.status || status==='' ? 'selected' : '' %>>All Statuses</option>
                <option value="Placed" <%=locals.status==='Placed' ? 'selected' : '' %>>Placed</option>
                <option value="Processing" <%=locals.status==='Processing' ? 'selected' : '' %>>Processing</option>
                <option value="Shipped" <%=locals.status==='Shipped' ? 'selected' : '' %>>Shipped</option>
                <option value="Delivered" <%=locals.status==='Delivered' ? 'selected' : '' %>>Delivered</option>
                <option value="Cancelled" <%=locals.status==='Cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>

              <!-- SORT -->
              <select class="filter-select" name="sort" onchange="document.getElementById('filterForm').submit()">
                <option value="newest" <%=!locals.sort || sort==='newest' ? 'selected' : '' %>>Newest First</option>
                <option value="oldest" <%=locals.sort==='oldest' ? 'selected' : '' %>>Oldest First</option>
                <option value="amount_high" <%=locals.sort==='amount_high' ? 'selected' : '' %>>Amount: High → Low
                </option>
                <option value="amount_low" <%=locals.sort==='amount_low' ? 'selected' : '' %>>Amount: Low → High
                </option>
              </select>

              <!-- CLEAR -->
              <% if ((locals.search && search.length> 0) || (locals.status && status.length > 0) || (locals.sort && sort
                !== 'newest')) { %>
                <a href="/admin/orders" class="btn-reset"><i class="fas fa-undo"></i> Clear</a>
                <% } %>

                  <div class="toolbar-right">
                    <span class="total-badge">Total: <strong>
                        <%= locals.total || 0 %>
                      </strong></span>
                  </div>
            </div>
          </form>

          <!-- TABLE -->
          <div class="table-card">
            <% if (locals.orders && orders.length> 0) { %>
              <table class="prod-table">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th class="col-hide">Items</th>
                    <th>Amount</th>
                    <th class="col-hide">Payment</th>
                    <th class="th-center">Status</th>
                    <th class="th-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% orders.forEach(function(order) { %>
                    <tr>
                      <td>
                        <div class="order-id">#<%= order.orderId %>
                        </div>
                      </td>
                      <td>
                        <div class="order-date">
                          <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short',
                            year:'numeric' }) %>
                        </div>
                        <div class="order-date" style="margin-top:0.1rem;">
                          <%= new Date(order.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit'
                            }) %>
                        </div>
                      </td>
                      <td>
                        <div class="customer-name">
                          <%= order.userId ? order.userId.name : order.shippingAddress.name %>
                        </div>
                        <div class="customer-email">
                          <%= order.userId ? order.userId.email : '' %>
                        </div>
                        <div class="customer-email"><i class="fas fa-phone" style="font-size:0.6rem;"></i>
                          <%= order.shippingAddress.mobile %>
                        </div>
                      </td>
                      <td class="col-hide">
                        <div class="order-items-count">
                          <%= order.items.length %> item<%= order.items.length !==1 ? 's' : '' %>
                        </div>
                        <div class="order-items-count"
                          style="margin-top:0.1rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px;">
                          <%= order.items[0].productName %>
                            <% if (order.items.length> 1) { %> +<%= order.items.length - 1 %> more<% } %>
                        </div>
                      </td>
                      <td>
                        <div class="order-amount">₹<%= order.finalAmount.toLocaleString('en-IN') %>
                        </div>
                      </td>
                      <td class="col-hide">
                        <span class="pay-tag">
                          <%= order.paymentMethod %>
                        </span>
                        <div style="font-size:0.68rem;color:var(--muted);margin-top:0.25rem;">
                          <%= order.paymentStatus %>
                        </div>
                      </td>
                      <td class="th-center">
                        <% const hasItemReturn=order.itemStatuses && order.itemStatuses.some(s=> s.status ===
                          'Returned')
                          const showReturn = (order.returnStatus && order.returnStatus !== 'None') || hasItemReturn
                          const returnLabel = (order.returnStatus && order.returnStatus !== 'None')
                          ? order.returnStatus : 'Requested'
                          %>
                          <% if (showReturn) { %>
                            <span class="status-badge status-Returned">
                              <i class="fas fa-undo"></i> Return: <%= returnLabel %>
                            </span>
                            <% } else { %>
                              <span class="status-badge status-<%= order.orderStatus %>">
                                <% if (order.orderStatus==='Delivered' ) { %><i class="fas fa-check-circle"></i>
                                  <% } else if (order.orderStatus==='Cancelled' ) { %><i
                                      class="fas fa-times-circle"></i>
                                    <% } else if (order.orderStatus==='Shipped' ) { %><i class="fas fa-truck"></i>
                                      <% } else { %><i class="fas fa-clock"></i>
                                        <% } %>
                                          <%= order.orderStatus %>
                              </span>
                              <% } %>
                      </td>
                      <td class="action-cell">
                        <div class="action-btns">
                          <a href="/admin/orders/<%= order._id %>" class="act-btn" title="View Detail">
                            <i class="fas fa-eye"></i>
                          </a>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>

              <!-- PAGINATION -->
              <% if (locals.totalPages && totalPages> 1) { %>
                <% const qs=`&search=${locals.search||''}&status=${locals.status||''}&sort=${locals.sort||'newest'}` %>
                  <div class="pagination-wrap">
                    <div class="pagination-info">
                      Showing
                      <strong>
                        <%= (currentPage - 1) * 10 + 1 %>–<%= Math.min(currentPage * 10, total) %>
                      </strong>
                      of <strong>
                        <%= total %>
                      </strong> orders
                    </div>
                    <ul class="pagination">
                      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/orders?page=<%= currentPage - 1 %><%= qs %>">
                          <i class="fas fa-chevron-left" style="font-size:0.65rem"></i>
                        </a>
                      </li>
                      <% let sp=Math.max(1, currentPage - 2); %>
                        <% let ep=Math.min(totalPages, sp + 4); %>
                          <% if (ep - sp < 4) sp=Math.max(1, ep - 4); %>
                            <% if (sp> 1) { %>
                              <li class="page-item"><a class="page-link" href="/admin/orders?page=1<%= qs %>">1</a></li>
                              <% if (sp> 2) { %><li class="page-item ellipsis"><span class="page-link">…</span></li>
                                <% } %>
                                  <% } %>
                                    <% for (let p=sp; p <=ep; p++) { %>
                                      <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                                        <a class="page-link" href="/admin/orders?page=<%= p %><%= qs %>">
                                          <%= p %>
                                        </a>
                                      </li>
                                      <% } %>
                                        <% if (ep < totalPages) { %>
                                          <% if (ep < totalPages - 1) { %>
                                            <li class="page-item ellipsis"><span class="page-link">…</span></li>
                                            <% } %>
                                              <li class="page-item"><a class="page-link"
                                                  href="/admin/orders?page=<%= totalPages %><%= qs %>">
                                                  <%= totalPages %>
                                                </a></li>
                                              <% } %>
                                                <li
                                                  class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                  <a class="page-link"
                                                    href="/admin/orders?page=<%= currentPage + 1 %><%= qs %>">
                                                    <i class="fas fa-chevron-right" style="font-size:0.65rem"></i>
                                                  </a>
                                                </li>
                    </ul>
                  </div>
                  <% } %>

                    <% } else { %>
                      <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                        <h3 class="empty-title">
                          <% if ((locals.search && search.length> 0) || (locals.status && status.length > 0)) { %>
                            No orders found
                            <% } else { %>
                              No orders yet
                              <% } %>
                        </h3>
                        <p class="empty-sub">
                          <% if ((locals.search && search.length> 0) || (locals.status && status.length > 0)) { %>
                            Try different filters or <a href="/admin/orders">clear all</a>.
                            <% } else { %>
                              Orders will appear here once customers place them.
                              <% } %>
                        </p>
                      </div>
                      <% } %>
          </div>

        </div>
        <%- include('../partials/admin/adminFooter') %>
      </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
  <script>
    var searchInput = document.getElementById('searchInput')
    var searchClear = document.getElementById('searchClear')
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        searchClear.classList.toggle('visible', this.value.length > 0)
      })
    }
    function clearSearch() {
      searchInput.value = ''
      searchClear.classList.remove('visible')
      window.location.href = '/admin/orders'
    }
  </script>
</body>

</html>