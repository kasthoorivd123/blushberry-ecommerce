<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard – Blush Berry Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --rose:    #c0415a;
      --rose-dk: #a33049;
      --rose-lt: #fce8ed;
      --ink:     #1a1a2e;
      --ink2:    #2e2e45;
      --muted:   #888;
      --border:  #f0e6e8;
      --bg:      #fafafa;
      --white:   #ffffff;
      --green:   #22b573;
      --amber:   #e8a826;
      --blue:    #3b82f6;
    }

    body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--ink); }
    a { text-decoration: none; color: inherit; }

    /* ── layout ── */
    .dash-wrap  { padding: 32px 36px; max-width: 1400px; margin: 0 auto; }
    .page-head  { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 14px; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 900; color: var(--ink); }
    .page-sub   { font-size: 12px; color: var(--muted); margin-top: 3px; }

    /* ── filter bar ── */
    .filter-bar { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .filter-btn {
      padding: 7px 16px; border: 1px solid var(--border); border-radius: 20px;
      font-size: 12px; font-weight: 500; background: var(--white); color: var(--muted);
      cursor: pointer; transition: all .2s;
    }
    .filter-btn:hover, .filter-btn.active { background: var(--rose); color: #fff; border-color: var(--rose); }
    .custom-range { display: flex; align-items: center; gap: 6px; }
    .custom-range input {
      padding: 6px 10px; border: 1px solid var(--border); border-radius: 6px;
      font-size: 12px; font-family: 'Poppins', sans-serif; color: var(--ink);
    }
    .custom-range input:focus { outline: none; border-color: var(--rose); }
    .btn-apply {
      padding: 7px 14px; background: var(--rose); color: #fff; border: none;
      border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer;
    }

    /* ── summary cards ── */
    .cards-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 28px; }
    .card {
      background: var(--white); border: 1px solid var(--border); border-radius: 14px;
      padding: 22px 24px; position: relative; overflow: hidden;
    }
    .card::before {
      content: ''; position: absolute; top: -30px; right: -30px;
      width: 90px; height: 90px; border-radius: 50%;
      background: var(--card-accent, var(--rose-lt)); opacity: .6;
    }
    .card-icon  { font-size: 24px; margin-bottom: 12px; }
    .card-label { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
    .card-value { font-size: 26px; font-weight: 700; color: var(--ink); line-height: 1; }
    .card-sub   { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .card-rose  { --card-accent: #fce8ed; border-top: 3px solid var(--rose); }
    .card-green { --card-accent: #e8f8f0; border-top: 3px solid var(--green); }
    .card-amber { --card-accent: #fff8e6; border-top: 3px solid var(--amber); }
    .card-blue  { --card-accent: #eff6ff; border-top: 3px solid var(--blue); }

    /* ── chart section ── */
    .chart-section {
      background: var(--white); border: 1px solid var(--border); border-radius: 14px;
      padding: 24px; margin-bottom: 28px;
    }
    .section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
    .section-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--ink); }
    .chart-type-btns { display: flex; gap: 6px; }
    .ctype-btn {
      padding: 5px 14px; border: 1px solid var(--border); border-radius: 20px;
      font-size: 11px; font-weight: 500; background: var(--white); color: var(--muted);
      cursor: pointer; transition: all .2s; text-decoration: none;
    }
    .ctype-btn.active, .ctype-btn:hover { background: var(--ink); color: #fff; border-color: var(--ink); }
    .chart-wrap { position: relative; height: 300px; }

    /* ── two-column grid for tables ── */
    .tables-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
    .table-section {
      background: var(--white); border: 1px solid var(--border); border-radius: 14px;
      padding: 22px; overflow: hidden;
    }
    .rank-table { width: 100%; border-collapse: collapse; }
    .rank-table th {
      font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted);
      font-weight: 600; padding: 0 10px 12px; text-align: left; border-bottom: 1px solid var(--border);
    }
    .rank-table th:last-child { text-align: right; }
    .rank-table td { padding: 11px 10px; font-size: 13px; color: var(--ink); border-bottom: 1px solid #fafafa; vertical-align: middle; }
    .rank-table tr:last-child td { border-bottom: none; }
    .rank-table td:last-child { text-align: right; font-weight: 600; color: var(--rose); }
    .rank-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 22px; height: 22px; border-radius: 50%;
      font-size: 10px; font-weight: 700;
      background: var(--rose-lt); color: var(--rose);
    }
    .rank-num.top { background: var(--rose); color: #fff; }
    .prod-thumb {
      width: 32px; height: 32px; border-radius: 6px; object-fit: cover;
      background: var(--rose-lt); vertical-align: middle; margin-right: 8px;
    }
    .prod-name-cell { display: flex; align-items: center; }
    .bar-cell { display: flex; align-items: center; gap: 8px; }
    .mini-bar-wrap { flex: 1; height: 6px; background: var(--rose-lt); border-radius: 3px; min-width: 60px; }
    .mini-bar { height: 100%; background: var(--rose); border-radius: 3px; }

    /* ── best brands (full width) ── */
    .brands-section {
      background: var(--white); border: 1px solid var(--border); border-radius: 14px;
      padding: 22px; margin-bottom: 28px;
    }
    .brands-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-top: 16px; }
    .brand-card {
      border: 1px solid var(--border); border-radius: 10px; padding: 16px 14px;
      text-align: center; transition: all .2s;
    }
    .brand-card:hover { border-color: var(--rose); box-shadow: 0 4px 16px rgba(192,65,90,.1); }
    .brand-rank { font-size: 10px; color: var(--muted); margin-bottom: 6px; }
    .brand-name { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .brand-qty  { font-size: 11px; color: var(--muted); }
    .brand-rev  { font-size: 14px; font-weight: 700; color: var(--rose); margin-top: 4px; }

    /* ── ledger ── */
    .ledger-section {
      background: var(--white); border: 1px solid var(--border); border-radius: 14px;
      padding: 22px; margin-bottom: 28px; overflow-x: auto;
    }
    .ledger-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .ledger-table { width: 100%; border-collapse: collapse; min-width: 700px; }
    .ledger-table th {
      font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted);
      font-weight: 600; padding: 0 12px 12px; text-align: left; border-bottom: 1px solid var(--border);
    }
    .ledger-table td { padding: 12px; font-size: 12px; color: var(--ink); border-bottom: 1px solid #fafafa; }
    .ledger-table tr:last-child td { border-bottom: none; }
    .status-pill {
      display: inline-block; padding: 2px 10px; border-radius: 20px;
      font-size: 10px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase;
    }
    .pill-delivered  { background: #e8f8f0; color: var(--green); }
    .pill-placed     { background: #eff6ff; color: var(--blue); }
    .pill-shipped    { background: #fff8e6; color: var(--amber); }
    .pill-cancelled  { background: #fce8e8; color: #e05555; }
    .pill-processing { background: #f3f0ff; color: #7c3aed; }
    .pill-returned   { background: #fafafa;  color: var(--muted); }
    .ledger-amount   { font-weight: 700; color: var(--green); }
    .ledger-discount { font-weight: 600; color: #e05555; }

    .btn-export {
      padding: 8px 18px; background: var(--ink); color: #fff; border: none;
      border-radius: 6px; font-size: 11px; font-weight: 600; letter-spacing: .5px;
      cursor: pointer; transition: background .2s;
    }
    .btn-export:hover { background: var(--rose); }

    /* ── empty state ── */
    .empty { text-align: center; padding: 32px; color: var(--muted); font-size: 13px; }

    /* ── date error ── */
    #dateError {
      font-size: 11px; color: #e05555; display: none;
      padding-left: 2px; margin-top: 4px;
    }

    @media (max-width: 1100px) {
      .cards-grid  { grid-template-columns: repeat(2, 1fr); }
      .tables-grid { grid-template-columns: 1fr; }
      .brands-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 640px) {
      .dash-wrap   { padding: 20px 16px; }
      .cards-grid  { grid-template-columns: 1fr 1fr; }
      .brands-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

  <%- include('../partials/admin/adminSidebar') %>

  <div class="dash-wrap">

    <!-- ── page head ── -->
    <div class="page-head">
      <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-sub">Blush Berry · Sales Overview</p>
      </div>

      <!-- ── filter bar ── -->
      <form method="GET" action="/admin/dashboard" class="filter-bar" id="filterForm" onsubmit="return validateDateRange(event)">

        <% ['today','week','month','year','monthly'].forEach(f => { %>
        <button type="submit" name="filter" value="<%= f %>"
          class="filter-btn <%= filter === f ? 'active' : '' %>">
          <%= f.charAt(0).toUpperCase() + f.slice(1) %>
        </button>
        <% }) %>

        <div style="display:flex;flex-direction:column;align-items:flex-start;gap:4px;">
          <div style="display:flex;align-items:center;gap:6px;">
            <input type="date" id="fromInput" name="from"
              value="<%= fromDate %>"
              max="<%= new Date().toISOString().split('T')[0] %>"
              onchange="onFromChange()"
              style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:12px;font-family:'Poppins',sans-serif;color:var(--ink);">
            <span style="font-size:12px;color:var(--muted)">–</span>
            <input type="date" id="toInput" name="to"
              value="<%= toDate %>"
              max="<%= new Date().toISOString().split('T')[0] %>"
              onchange="onToChange()"
              style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:12px;font-family:'Poppins',sans-serif;color:var(--ink);">
            <button type="submit" name="filter" value="custom" class="btn-apply">Apply</button>
          </div>
          <span id="dateError"></span>
        </div>

      </form>
    </div><!-- /page-head -->

    <!-- ── summary cards ── -->
    <div class="cards-grid">
      <div class="card card-rose">
        <div class="card-icon">💰</div>
        <p class="card-label">Total Revenue</p>
        <p class="card-value">₹<%= (summary.totalRevenue || 0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2}) %></p>
        <p class="card-sub">Net after discounts</p>
      </div>
      <div class="card card-green">
        <div class="card-icon">📦</div>
        <p class="card-label">Total Orders</p>
        <p class="card-value"><%= summary.totalOrders || 0 %></p>
        <p class="card-sub">Excluding cancelled &amp; returned</p>
      </div>
      <div class="card card-amber">
        <div class="card-icon">🏷️</div>
        <p class="card-label">Total Discount</p>
        <p class="card-value">₹<%= (summary.totalDiscount || 0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2}) %></p>
        <p class="card-sub">Coupons + item offers</p>
      </div>
      <div class="card card-blue">
        <div class="card-icon">👤</div>
        <p class="card-label">Total Users</p>
        <p class="card-value"><%= summary.totalUsers || 0 %></p>
        <p class="card-sub">Registered accounts</p>
      </div>
    </div>

    <!-- ── chart ── -->
    <div class="chart-section">
      <div class="section-head">
        <h2 class="section-title">Sales Chart</h2>
        <div class="chart-type-btns">
          <a href="?filter=<%= filter %>&chartType=revenue&from=<%= fromDate %>&to=<%= toDate %>"
             class="ctype-btn <%= chartType === 'revenue'  ? 'active' : '' %>">Revenue</a>
          <a href="?filter=<%= filter %>&chartType=orders&from=<%= fromDate %>&to=<%= toDate %>"
             class="ctype-btn <%= chartType === 'orders'   ? 'active' : '' %>">Orders</a>
          <a href="?filter=<%= filter %>&chartType=discount&from=<%= fromDate %>&to=<%= toDate %>"
             class="ctype-btn <%= chartType === 'discount' ? 'active' : '' %>">Discount</a>
        </div>
      </div>
      <div class="chart-wrap">
        <canvas id="salesChart"></canvas>
      </div>
    </div>

    <!-- ── best selling products + categories ── -->
    <div class="tables-grid">

      <!-- products -->
      <div class="table-section">
        <div class="section-head">
          <h2 class="section-title">Top Products</h2>
          <span style="font-size:11px;color:var(--muted)">by units sold</span>
        </div>
        <% if (bestProducts.length === 0) { %>
          <p class="empty">No sales data yet.</p>
        <% } else { %>
          <% const maxPQty = bestProducts[0]?.totalQty || 1 %>
          <table class="rank-table">
            <thead><tr><th>#</th><th>Product</th><th>Qty</th><th>Revenue</th></tr></thead>
            <tbody>
            <% bestProducts.forEach((p, i) => { %>
            <tr>
              <td><span class="rank-num <%= i < 3 ? 'top' : '' %>"><%= i+1 %></span></td>
              <td>
                <div class="prod-name-cell">
                  <% if (p.image) { %>
                    <img src="<%= p.image %>" class="prod-thumb" alt="<%= p.name %>">
                  <% } else { %>
                    <span style="font-size:22px;margin-right:8px;">💄</span>
                  <% } %>
                  <span style="font-size:12px;font-weight:500;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= p.name %>"><%= p.name %></span>
                </div>
              </td>
              <td>
                <div class="bar-cell">
                  <div class="mini-bar-wrap">
                    <div class="mini-bar" style="width:<%= Math.round((p.totalQty/maxPQty)*100) %>%"></div>
                  </div>
                  <span style="font-size:12px;min-width:24px;"><%= p.totalQty %></span>
                </div>
              </td>
              <td>₹<%= (p.totalRevenue||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

      <!-- categories -->
      <div class="table-section">
        <div class="section-head">
          <h2 class="section-title">Top Categories</h2>
          <span style="font-size:11px;color:var(--muted)">by units sold</span>
        </div>
        <% if (bestCategories.length === 0) { %>
          <p class="empty">No sales data yet.</p>
        <% } else { %>
          <% const maxCQty = bestCategories[0]?.totalQty || 1 %>
          <table class="rank-table">
            <thead><tr><th>#</th><th>Category</th><th>Qty</th><th>Revenue</th></tr></thead>
            <tbody>
            <% bestCategories.forEach((c, i) => { %>
            <tr>
              <td><span class="rank-num <%= i < 3 ? 'top' : '' %>"><%= i+1 %></span></td>
              <td style="font-size:13px;font-weight:500;"><%= c.name || 'Unknown' %></td>
              <td>
                <div class="bar-cell">
                  <div class="mini-bar-wrap">
                    <div class="mini-bar" style="width:<%= Math.round((c.totalQty/maxCQty)*100) %>%"></div>
                  </div>
                  <span style="font-size:12px;min-width:24px;"><%= c.totalQty %></span>
                </div>
              </td>
              <td>₹<%= (c.totalRevenue||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

    </div>

    <!-- ── best selling brands ── -->
    <div class="brands-section">
      <div class="section-head">
        <h2 class="section-title">Top Brands</h2>
        <span style="font-size:11px;color:var(--muted)">by units sold</span>
      </div>
      <% if (bestBrands.length === 0) { %>
        <p class="empty">No brand data yet.</p>
      <% } else { %>
        <div class="brands-grid">
          <% bestBrands.forEach((b, i) => { %>
          <div class="brand-card">
            <p class="brand-rank">#<%= i+1 %></p>
            <p class="brand-name"><%= b._id || 'Unknown' %></p>
            <p class="brand-qty"><%= b.totalQty %> units sold</p>
            <p class="brand-rev">₹<%= (b.totalRevenue||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></p>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- ── ledger ── -->
    <div class="ledger-section">
      <div class="ledger-head">
        <h2 class="section-title">Ledger Book</h2>
        <button class="btn-export" onclick="exportLedger()">⬇ Export CSV</button>
      </div>
      <% if (ledger.length === 0) { %>
        <p class="empty">No transactions in this period.</p>
      <% } else { %>
        <table class="ledger-table" id="ledgerTable">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Date</th>
              <th>Customer</th>
              <th>Items</th>
              <th>Payment</th>
              <th>Status</th>
              <th>Discount</th>
              <th>Amount</th>
            </tr>
          </thead>
          <tbody>
          <% ledger.forEach(order => { %>
          <tr>
            <td style="font-family:monospace;font-size:11px;"><%= order.orderId %></td>
            <td><%= new Date(order.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
            <td>
              <div style="font-weight:500;"><%= order.userId?.fullName || order.shippingAddress?.name || '—' %></div>
              <div style="font-size:10px;color:var(--muted);"><%= order.userId?.email || '' %></div>
            </td>
            <td style="color:var(--muted);"><%= order.items.length %> item<%= order.items.length !== 1 ? 's' : '' %></td>
            <td>
              <span style="font-size:11px;background:#f5f5f5;padding:2px 8px;border-radius:10px;">
                <%= order.paymentMethod %>
              </span>
            </td>
            <td>
              <span class="status-pill pill-<%= order.orderStatus.toLowerCase() %>">
                <%= order.orderStatus %>
              </span>
            </td>
            <td class="ledger-discount">
              <% if (order.totalDiscount > 0) { %>
                −₹<%= order.totalDiscount.toLocaleString('en-IN',{maximumFractionDigits:2}) %>
              <% } else { %>
                <span style="color:var(--muted)">—</span>
              <% } %>
            </td>
            <td class="ledger-amount">₹<%= order.finalAmount.toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2}) %></td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

  </div><!-- /dash-wrap -->

  <%- include('../partials/admin/adminFooter') %>

  <script>
    // ── chart ──────────────────────────────────────────────────────────────────
    const labels   = <%- chartLabels %>
    const revenue  = <%- chartRevenue %>
    const orders   = <%- chartOrders %>
    const discount = <%- chartDiscount %>
    const ctype    = '<%= chartType %>'

    const datasets = {
      revenue:  { label: 'Revenue (₹)', data: revenue,  color: '#c0415a' },
      orders:   { label: 'Orders',       data: orders,   color: '#3b82f6' },
      discount: { label: 'Discount (₹)', data: discount, color: '#e8a826' }
    }

    const active = datasets[ctype] || datasets.revenue

    new Chart(document.getElementById('salesChart'), {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: active.label,
          data:  active.data,
          backgroundColor: active.color + '22',
          borderColor:     active.color,
          borderWidth:     2,
          borderRadius:    6,
          tension:         0.4,
          fill:            true,
          type: labels.length > 15 ? 'line' : 'bar'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => {
                const v = ctx.parsed.y
                return ctype === 'orders' ? ` ${v} orders` : ` ₹${Number(v).toLocaleString('en-IN')}`
              }
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { font: { family: 'Poppins', size: 11 }, maxRotation: 45 }
          },
          y: {
            grid: { color: '#f0e6e8' },
            ticks: {
              font: { family: 'Poppins', size: 11 },
              callback: v => ctype === 'orders' ? v : '₹' + Number(v).toLocaleString('en-IN')
            }
          }
        }
      }
    })

    // ── CSV export ─────────────────────────────────────────────────────────────
    function exportLedger() {
      const table = document.getElementById('ledgerTable')
      if (!table) return alert('No ledger data to export.')
      const rows = [...table.querySelectorAll('tr')]
      const csv  = rows.map(r =>
        [...r.querySelectorAll('th,td')]
          .map(c => '"' + c.innerText.replace(/"/g, '""').replace(/\n/g, ' ') + '"')
          .join(',')
      ).join('\n')

      const blob = new Blob([csv], { type: 'text/csv' })
      const url  = URL.createObjectURL(blob)
      const a    = document.createElement('a')
      a.href     = url
      a.download = `blushberry-ledger-${new Date().toISOString().split('T')[0]}.csv`
      a.click()
      URL.revokeObjectURL(url)
    }

    // ── date validation ────────────────────────────────────────────────────────
    const today = new Date().toISOString().split('T')[0]

    function showDateError(msg) {
      const err = document.getElementById('dateError')
      err.textContent  = msg
      err.style.display = msg ? 'block' : 'none'
    }

    function clearDateError() {
      showDateError('')
    }

    function highlightInput(id, isError) {
      document.getElementById(id).style.borderColor = isError ? '#e05555' : 'var(--border)'
    }

    function onFromChange() {
      const from = document.getElementById('fromInput')
      const to   = document.getElementById('toInput')
      clearDateError()
      highlightInput('fromInput', false)
      highlightInput('toInput',   false)

      if (from.value > today) {
        from.value = today
        showDateError('"From" date cannot be in the future.')
        highlightInput('fromInput', true)
        return
      }
      if (to.value && from.value > to.value) {
        showDateError('"From" date cannot be later than "To" date.')
        highlightInput('fromInput', true)
        highlightInput('toInput',   true)
        return
      }
      to.min = from.value || ''
    }

    function onToChange() {
      const from = document.getElementById('fromInput')
      const to   = document.getElementById('toInput')
      clearDateError()
      highlightInput('fromInput', false)
      highlightInput('toInput',   false)

      if (to.value > today) {
        to.value = today
        showDateError('"To" date cannot be in the future.')
        highlightInput('toInput', true)
        return
      }
      if (from.value && to.value < from.value) {
        showDateError('"To" date cannot be earlier than "From" date.')
        highlightInput('fromInput', true)
        highlightInput('toInput',   true)
        return
      }
    }

    function validateDateRange(e) {
      // Skip validation for preset filter buttons — only validate the Apply button
      if (e.submitter && e.submitter.value !== 'custom') return true

      const from = document.getElementById('fromInput')
      const to   = document.getElementById('toInput')

      clearDateError()
      highlightInput('fromInput', false)
      highlightInput('toInput',   false)

      if (!from.value || !to.value) {
        showDateError('Please select both a "From" and "To" date.')
        if (!from.value) highlightInput('fromInput', true)
        if (!to.value)   highlightInput('toInput',   true)
        e.preventDefault()
        return false
      }

      if (from.value > today || to.value > today) {
        showDateError('Dates cannot be in the future.')
        if (from.value > today) highlightInput('fromInput', true)
        if (to.value   > today) highlightInput('toInput',   true)
        e.preventDefault()
        return false
      }

      if (from.value > to.value) {
        showDateError('"From" date must be before or equal to "To" date.')
        highlightInput('fromInput', true)
        highlightInput('toInput',   true)
        e.preventDefault()
        return false
      }

      return true
    }
  </script>
</body>
</html>
