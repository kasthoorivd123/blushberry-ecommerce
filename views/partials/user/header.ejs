<nav style="position:sticky;top:0;z-index:1000;background:#fff;border-bottom:1px solid #f2e6e9;padding:0 48px;height:60px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
 <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Poppins', sans-serif; background: #fff; color: #cd7878; overflow-x: hidden; }
    a { text-decoration: none; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
    @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
    .fade-up { animation: fadeUp 0.7s ease both; }
    .nav-link:hover { color: #c0415a !important; border-bottom: 2px solid #c0415a; padding-bottom: 2px; }
    .shade-card:hover { box-shadow: 0 12px 40px rgba(192,65,90,0.15) !important; transform: translateY(-4px); transition: all 0.3s ease; }
    .product-card:hover { box-shadow: 0 12px 36px rgba(0,0,0,0.12) !important; transform: translateY(-4px); transition: all 0.3s ease; }
    .btn-cart:hover { background: #c0415a !important; }
    .btn-shop:hover { background: #a33049 !important; }

  
  </style>
  <!-- Logo -->
  <a href="/" style="font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:#c0415a;letter-spacing:-0.5px;">
    Blush<span style="color:#1a1a2e;">Berry</span>
  </a>

  <!-- Nav Links -->
   <!-- Nav Links -->
<ul style="list-style:none;display:flex;gap:36px;align-items:center;">
    <li><a href="/" class="nav-link" style="font-size:13px;font-weight:500;color:<%= currentPath === '/' ? '#c0415a' : '#555' %>;">Home</a></li>
    <li><a href="/products" class="nav-link" style="font-size:13px;font-weight:400;color:<%= currentPath === '/products' ? '#c0415a' : '#555' %>;">Shop</a></li>
    <li><a href="/orders" class="nav-link" style="font-size:13px;font-weight:400;color:<%= currentPath === '/orders' ? '#c0415a' : '#555' %>;">Order</a></li>
    <li><a href="/contact" class="nav-link" style="font-size:13px;font-weight:400;color:<%= currentPath === '/contact' ? '#c0415a' : '#555' %>;">Contact</a></li>
    <li>
      <a href="/wishlist" style="position:relative;display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:#fff5f7;border:1px solid #f2e6e9;text-decoration:none;transition:background 0.2s;" title="Wishlist"
        onmouseover="this.style.background='#fde8ed'" onmouseout="this.style.background='#fff5f7'">
        <svg width="16" height="16" fill="none" stroke="#c0415a" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <% if (typeof wishlistCount !== 'undefined' && wishlistCount > 0) { %>
          <span style="position:absolute;top:-4px;right:-4px;background:#c0415a;color:#fff;font-size:9px;font-weight:700;font-family:'Poppins',sans-serif;min-width:16px;height:16px;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 3px;line-height:1;">
            <%= wishlistCount %>
          </span>
        <% } %>
      </a>
    </li>

    <!-- Cart Icon -->
    <li>
      <a href="/cart" style="position:relative;display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:#fff5f7;border:1px solid #f2e6e9;text-decoration:none;transition:background 0.2s;" title="Cart"
        onmouseover="this.style.background='#fde8ed'" onmouseout="this.style.background='#fff5f7'">
        <svg width="16" height="16" fill="none" stroke="#c0415a" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span style="position:absolute;top:-4px;right:-4px;background:#c0415a;color:#fff;font-size:9px;font-weight:700;font-family:'Poppins',sans-serif;min-width:16px;height:16px;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 3px;line-height:1;">
            <%= cartCount %>
          </span>
        <% } %>
      </a>
    </li>

    <% if (!user) { %>

      <!-- NOT LOGGED IN: Login button -->
      <li>
        <a href="/login" style="display:flex;align-items:center;gap:6px;text-decoration:none;background:#c0415a;color:#fff;padding:8px 18px;border-radius:20px;font-size:13px;font-weight:600;font-family:'Poppins',sans-serif;">
          <svg width="15" height="15" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="4"/>
            <path d="M6 20c0-3.33 5.33-5 6-5s6 1.67 6 5"/>
          </svg>
          Login
        </a>
      </li>

    <% } else { %>

      <!-- LOGGED IN: SVG avatar + first name + dropdown -->
      <li style="position:relative;">

        <button id="profileBtn" style="background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:8px;">
          <!-- Profile photo or SVG fallback -->
          <% if (user.profilePhoto) { %>
            <img
              src="<%= user.profilePhoto.replace('s96-c', 's200-c') %>"
              alt="Profile"
              style="width:34px;height:34px;min-width:34px;min-height:34px;border-radius:50%;object-fit:cover;object-position:center;border:2px solid #e8c8d0;flex-shrink:0;display:block;"
            >
          <% } else { %>
            <div style="width:34px;height:34px;border-radius:50%;background:#f0e6e9;border:2px solid #e8c8d0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" fill="none" stroke="#c0415a" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="4"/>
                <path d="M6 20c0-3.33 5.33-5 6-5s6 1.67 6 5"/>
              </svg>
            </div>
          <% } %>
          <!-- First name -->
          <span style="font-size:13px;font-weight:600;color:#1a1a2e;font-family:'Poppins',sans-serif;">
            <%= user.fullName ? user.fullName.split(' ')[0] : (user.name ? user.name.split(' ')[0] : 'Account') %>
          </span>
          <!-- Chevron -->
          <svg width="12" height="12" fill="none" stroke="#888" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>

        <!-- Dropdown -->
        <ul id="profileDropdown" style="display:none;position:absolute;top:44px;right:0;background:#fff;border:1px solid #eee;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.1);list-style:none;padding:8px 0;min-width:140px;z-index:100;">
          <li>
            <a href="/profile" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#555;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#888" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20c0-3.33 5.33-5 6-5s6 1.67 6 5"/></svg>
              My Profile
            </a>
          </li>
          <li>
            <a href="/orders" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#555;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#888" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              My Orders
            </a>
          </li>
          <li>
            <a href="/wishlist" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#555;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#888" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              My Wishlist
            </a>
          </li>
          <li>
            <a href="/cart" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#555;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#888" stroke-width="2" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              My Cart
            </a>
          </li>
          <li style="border-top:1px solid #f5e8ec;margin-top:4px;padding-top:4px;">
            <a href="/logout" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#c0415a;font-weight:600;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#c0415a" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
              Log out
            </a>
          </li>
        </ul>

      </li>
    <% } %>
  </ul>
</nav>

<script>
  var profileBtn = document.getElementById('profileBtn');
  var profileDropdown = document.getElementById('profileDropdown');

  if (profileBtn && profileDropdown) {
    profileBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      if (profileDropdown.style.display === 'block') {
        profileDropdown.style.display = 'none';
      } else {
        profileDropdown.style.display = 'block';
      }
    });

    document.addEventListener('click', function (e) {
      if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
        profileDropdown.style.display = 'none';
      }
    });
  }
</script>
